    "def select_model_from_summary(summary_df, by_seed_df, selection_split, selection_metric):\n",
    "    \"\"\"validation 평균 성능 기준으로 모델 유형을 선택하고, 해당 유형 안에서 seed를 선택합니다.\"\"\"\n",
    "    summary_metric_col = f\"{selection_metric}_mean\"\n",
    "    selection_df = summary_df[summary_df[\"split\"].eq(selection_split)].copy()\n",
    "\n",
    "    if not len(selection_df) or summary_metric_col not in selection_df.columns:\n",
    "        return {}\n",
    "\n",
    "    selection_df = selection_df.sort_values(\n",
    "        [summary_metric_col, \"best_valid_score_mean\"],\n",
    "        ascending=[False, False],\n",
    "    )\n",
    "    best_summary_row = selection_df.iloc[0]\n",
    "    selected_model_key = str(best_summary_row[\"model_key\"])\n",
    "    selected_model_label = str(best_summary_row[\"model\"])\n",
    "\n",
    "    seed_selection_df = by_seed_df[\n",
    "        by_seed_df[\"split\"].eq(selection_split)\n",
    "        & by_seed_df[\"model_key\"].eq(selected_model_key)\n",
    "    ].copy()\n",
    "\n",
    "    if not len(seed_selection_df):\n",
    "        return {}\n",
    "\n",
    "    if selection_metric in seed_selection_df.columns:\n",
    "        seed_selection_df = seed_selection_df.sort_values(\n",
    "            [selection_metric, \"best_valid_score\"],\n",
    "            ascending=[False, False],\n",
    "        )\n",
    "    else:\n",
    "        seed_selection_df = seed_selection_df.sort_values([\"best_valid_score\"], ascending=[False])\n",
    "\n",
    "    selected_seed = int(seed_selection_df.iloc[0][\"seed\"])\n",
    "\n",
    "    return {\n",
    "        \"selection_split\": selection_split,\n",
    "        \"selection_metric\": selection_metric,\n",
    "        \"selected_model_key\": selected_model_key,\n",
    "        \"selected_model\": selected_model_label,\n",
    "        \"selected_seed\": selected_seed,\n",
    "        \"selection_score_mean\": float(best_summary_row[summary_metric_col]),\n",
    "        \"selection_score_std\": float(best_summary_row.get(f\"{selection_metric}_std\", np.nan)),\n",
    "    }"
   ]
  },
