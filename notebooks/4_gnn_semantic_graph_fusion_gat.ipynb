    "def edges_to_triples(df, node2idx, edge_type2idx):\n",
    "    if df is None or len(df) == 0:\n",
    "        return torch.empty((0, 3), dtype=torch.long)\n",
    "    valid = df[\n",
    "        df[source_col].isin(node2idx)\n",
    "        & df[target_col].isin(node2idx)\n",
    "        & df[edge_type_col].isin(edge_type2idx)\n",
    "    ].copy()\n",
    "    src = valid[source_col].map(node2idx).astype(int).values\n",
    "    rel = valid[edge_type_col].map(edge_type2idx).astype(int).values\n",
    "    dst = valid[target_col].map(node2idx).astype(int).values\n",
    "    return torch.tensor(np.vstack([src, rel, dst]).T, dtype=torch.long)"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "def build_message_passing_graph(train_graph_edges_df, node2idx, edge_type2idx):\n",
    "    triples = edges_to_triples(train_graph_edges_df, node2idx, edge_type2idx)\n",
    "    if triples.numel() == 0:\n",
    "        raise ValueError(\"학습 그래프 edge가 없습니다.\")\n",
    "\n",
    "    edge_index = torch.stack([triples[:, 0], triples[:, 2]], dim=0)\n",
    "    edge_type = triples[:, 1]\n",
    "    num_base_relations = len(edge_type2idx)\n",
    "\n",
    "    if CONFIG.get(\"add_reverse_edges\", True):\n",
    "        rev_edge_index = edge_index[[1, 0], :]\n",
    "        rev_edge_type = edge_type + num_base_relations\n",
    "        edge_index = torch.cat([edge_index, rev_edge_index], dim=1)\n",
    "        edge_type = torch.cat([edge_type, rev_edge_type], dim=0)\n",
    "        num_relations_for_mp = num_base_relations * 2\n",
    "    else:\n",
    "        num_relations_for_mp = num_base_relations\n",
    "\n",
    "    return edge_index, edge_type, num_relations_for_mp"
   ]
  },
