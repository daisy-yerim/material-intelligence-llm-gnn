    "def load_embedding_matrix(path):\n",
    "    path = Path(path)\n",
    "    suffix = path.suffix.lower()\n",
    "    if suffix == \".npy\":\n",
    "        arr = np.load(path, allow_pickle=True)\n",
    "    elif suffix == \".npz\":\n",
    "        z = np.load(path, allow_pickle=True)\n",
    "        first_key = list(z.keys())[0]\n",
    "        arr = z[first_key]\n",
    "    elif suffix in [\".pkl\", \".pickle\"]:\n",
    "        with open(path, \"rb\") as f:\n",
    "            obj = pickle.load(f)\n",
    "        if isinstance(obj, pd.DataFrame):\n",
    "            emb_col = detect_embedding_col(obj)\n",
    "            if emb_col is not None:\n",
    "                parsed = [parse_embedding(v) for v in obj[emb_col].tolist()]\n",
    "                arr = np.vstack([e for e in parsed if e is not None])\n",
    "            else:\n",
    "                arr = obj.select_dtypes(include=[np.number]).values\n",
    "        elif isinstance(obj, dict):\n",
    "            arr = None\n",
    "            for v in obj.values():\n",
    "                vv = np.array(v)\n",
    "                if vv.ndim == 2:\n",
    "                    arr = vv\n",
    "                    break\n",
    "            if arr is None:\n",
    "                raise ValueError(\"pkl dict 안에서 2D 임베딩 배열을 찾지 못했습니다.\")\n",
    "        else:\n",
    "            arr = np.array(obj)\n",
    "    else:\n",
    "        raise ValueError(f\"지원하지 않는 임베딩 파일 형식: {path}\")\n",
    "\n",
    "    arr = np.array(arr, dtype=np.float32)\n",
    "    if arr.ndim != 2:\n",
    "        raise ValueError(f\"임베딩 배열은 2차원이어야 합니다. 현재 shape={arr.shape}\")\n",
    "    return arr"
   ]
  },
