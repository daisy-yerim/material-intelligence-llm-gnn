    "## 9. Attention 기반 관계 중요도 추출\n",
    "\n",
    "attention 기반 모델(`relation_attention_gat`, `semantic_graph_fusion_gat`, `enhanced_semantic_graph_fusion_gat`)을 사용한 경우, layer 2의 attention weight를 평균하여 어떤 edge가 메시지 embedding 생성에 더 크게 기여했는지 확인합니다.\n",
    "\n",
    "이 결과는 모델의 완전한 설명은 아니지만, 제안서의 설명 가능성 관점에서 **GNN이 중요하게 본 관계 후보**를 점검하는 보조 근거로 사용할 수 있습니다.\n"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "id": "af2fde50",
   "metadata": {},
   "outputs": [],
   "source": [
    "def mp_relation_name(rel_idx):\n",
    "    rel_idx = int(rel_idx)\n",
    "    base_n = len(edge_type2idx)\n",
    "    if rel_idx >= base_n:\n",
    "        return \"reverse__\" + idx2edge_type.get(rel_idx - base_n, str(rel_idx - base_n))\n",
    "    return idx2edge_type.get(rel_idx, str(rel_idx))\n",
    "\n",
    "@torch.no_grad()\n",
    "def export_attention_edge_importance(model, top_n=1000):\n",
    "    if not hasattr(model, \"encode_with_attention\"):\n",
    "        print(\"현재 모델은 attention weight 추출을 지원하지 않습니다. attention 계열 모델인지 확인하세요.\")\n",
    "        return pd.DataFrame()\n",
    "\n",
    "    z_attn, attn_dict = model.encode_with_attention(\n",
    "        x.to(device),\n",
    "        edge_index.to(device),\n",
    "        edge_type.to(device),\n",
    "    )\n",
    "    # GATv2Conv return_attention_weights: (edge_index, alpha)\n",
    "    attn_edge_index, alpha = attn_dict[\"layer2\"]\n",
    "    alpha_np = alpha.detach().cpu().numpy()\n",
    "    if alpha_np.ndim == 2:\n",
    "        score = alpha_np.mean(axis=1)\n",
    "    else:\n",
    "        score = alpha_np\n",
    "\n",
    "    ei = attn_edge_index.detach().cpu().numpy()\n",
    "    et = edge_type.detach().cpu().numpy()\n",
    "    rows = []\n",
    "    for j in range(ei.shape[1]):\n",
    "        src_idx = int(ei[0, j])\n",
    "        dst_idx = int(ei[1, j])\n",
    "        rel_idx = int(et[j]) if j < len(et) else -1\n",
    "        rows.append({\n",
    "            \"src_idx\": src_idx,\n",
    "            \"src_node_id\": idx2node.get(src_idx, \"\"),\n",
    "            \"src_name\": node_display_name(idx2node.get(src_idx, \"\")),\n",
    "            \"dst_idx\": dst_idx,\n",
    "            \"dst_node_id\": idx2node.get(dst_idx, \"\"),\n",
    "            \"dst_name\": node_display_name(idx2node.get(dst_idx, \"\")),\n",
    "            \"message_passing_relation\": mp_relation_name(rel_idx),\n",
    "            \"attention_score\": float(score[j]),\n",
    "        })\n",
    "    attn_df = pd.DataFrame(rows).sort_values(\"attention_score\", ascending=False).head(top_n)\n",
    "    attn_df.to_csv(f\"{CONFIG['out_dir']}/attention_edge_importance.csv\", index=False, encoding=\"utf-8-sig\")\n",
    "    return attn_df\n",
    "\n",
    "attention_df = export_attention_edge_importance(model, top_n=1000)\n",
    "if len(attention_df) > 0:\n",
    "    display(attention_df.head(30))\n",
    "else:\n",
    "    print(\"attention_df가 비어 있습니다.\")\n"
   ]
  },
  {
   "cell_type": "markdown",
   "id": "5fce4500",
   "metadata": {},
   "source": [
    "## 10. 선택: Ollama LLM으로 GNN 추천 결과 설명 생성\n",
    "\n",
    "제안서의 **LLM-GNN 하이브리드 설명 가능성**에 맞춘 선택 셀입니다.\n",
    "\n",
    "- `CONFIG[\"enable_ollama_explanation\"] = True`로 바꾸면 실행됩니다.\n",
    "- Ollama 서버가 켜져 있어야 합니다.\n",
    "- 이 단계는 모델 학습이 아니라, GNN 결과를 사람이 읽을 수 있게 요약하는 후처리입니다.\n"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "id": "86ac5622",
   "metadata": {},
   "outputs": [],
   "source": [
    "def call_ollama_generate(prompt, model=None, url=None, timeout=120):\n",
    "    model = model or CONFIG[\"gemma_model\"]\n",
    "    url = url or CONFIG[\"ollama_url\"]\n",
    "    payload = {\n",
    "        \"model\": model,\n",
    "        \"prompt\": prompt,\n",
    "        \"stream\": False,\n",
    "        \"options\": {\n",
    "            \"temperature\": 0.2,\n",
    "            \"top_p\": 0.9,\n",
    "        }\n",
    "    }\n",
    "    res = requests.post(url, json=payload, timeout=timeout)\n",
    "    res.raise_for_status()\n",
    "    data = res.json()\n",
    "    return data.get(\"response\", \"\")\n",
    "\n",
    "def build_explanation_prompt(message_row, rec_rows, sim_rows):\n",
    "    rec_text = \"\\n\".join(\n",
    "        f\"- {r['relation']} → {r['candidate_name']} (score={r['score']:.3f}, confidence={r['confidence']:.3f}, observed={r['observed_in_original_graph']})\"\n",
    "        for _, r in rec_rows.head(8).iterrows()\n",
    "    )\n",
    "    sim_text = \"\\n\".join(\n",
    "        f\"- {r.get('similar_message_id','')}: {str(r.get('similar_message_text',''))[:120]} (sim={r.get('graph_similarity',0):.3f})\"\n",
    "        for _, r in sim_rows.head(5).iterrows()\n",
    "    )\n",
    "\n",
    "    return f'''\n",
    "너는 ERP/MES 로그 분석 전문가다.\n",
    "아래 메시지에 대해 GNN 관계 학습 결과를 바탕으로 원인 후보와 관련 사례를 간결하게 설명하라.\n",
    "규칙:\n",
    "1. 확정 표현을 피하고 '후보', '가능성'으로 표현한다.\n",
    "2. GNN이 추천한 관계와 유사 사례를 근거로 든다.\n",
    "3. 마지막에 사람이 확인해야 할 검증 포인트를 2~3개 제시한다.\n",
    "\n",
    "[메시지]\n",
    "- ID: {message_row.get('message_id','')}\n",
    "- Source: {message_row.get('source_domain','')}\n",
    "- Type: {message_row.get('message_type','')}\n",
    "- Text: {message_row.get('message_text','')}\n",
    "- LLM 의미 맥락: {message_row.get('problem_type_context','')} / {message_row.get('cluster_name_final_context','')}\n",
    "\n",
    "[GNN 원인 후보]\n",
    "{rec_text}\n",
    "\n",
    "[GNN 유사 이슈]\n",
    "{sim_text}\n",
    "\n",
    "[출력 형식]\n",
    "- 원인 후보 요약:\n",
    "- 관계 근거:\n",
    "- 유사 사례 근거:\n",
    "- 확인 필요 사항:\n",
    "'''.strip()\n",
    "\n",
    "if CONFIG.get(\"enable_ollama_explanation\", False):\n",
    "    explanations = []\n",
    "    if len(recommend_df) == 0:\n",
    "        print(\"recommend_df가 비어 있어 LLM 설명을 생성하지 않습니다.\")\n",
    "    else:\n",
    "        unique_messages = recommend_df[\"message_node_id\"].drop_duplicates().head(CONFIG[\"max_llm_explain_messages\"]).tolist()\n",
    "        for msg_node in unique_messages:\n",
    "            message_row = recommend_df[recommend_df[\"message_node_id\"].eq(msg_node)].iloc[0].to_dict()\n",
    "            rec_rows = recommend_df[recommend_df[\"message_node_id\"].eq(msg_node)].sort_values(\"score\", ascending=False)\n",
    "            sim_rows = similar_df[similar_df[\"message_node_id\"].eq(msg_node)].sort_values(\"graph_similarity\", ascending=False) if len(similar_df) else pd.DataFrame()\n",
    "            prompt = build_explanation_prompt(message_row, rec_rows, sim_rows)\n",
    "            try:\n",
    "                answer = call_ollama_generate(prompt)\n",
    "            except Exception as e:\n",
    "                answer = f\"[ERROR] Ollama 호출 실패: {e}\"\n",
    "            explanations.append({\n",
    "                \"message_node_id\": msg_node,\n",
    "                \"message_id\": message_row.get(\"message_id\", \"\"),\n",
    "                \"message_text\": message_row.get(\"message_text\", \"\"),\n",
    "                \"llm_explanation\": answer,\n",
    "            })\n",
    "        explanation_df = pd.DataFrame(explanations)\n",
    "        display(explanation_df)\n",
    "        explanation_df.to_csv(f\"{CONFIG['out_dir']}/llm_explanations_for_gnn_results.csv\", index=False, encoding=\"utf-8-sig\")\n",
    "else:\n",
    "    print(\"Ollama 설명 생성은 비활성화되어 있습니다. 필요하면 CONFIG['enable_ollama_explanation'] = True로 변경하세요.\")\n"
   ]
  },
