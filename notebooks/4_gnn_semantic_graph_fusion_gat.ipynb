   "cell_type": "code",
   "execution_count": null,
   "id": "8888dc57",
   "metadata": {},
   "outputs": [],
   "source": [
    "def build_edge_evidence_map(edges_df, max_items=12):\n",
    "    evidence = defaultdict(list)\n",
    "    for _, r in edges_df.iterrows():\n",
    "        s = str(r[source_col])\n",
    "        t = str(r[target_col])\n",
    "        et = str(r[edge_type_col])\n",
    "        evidence[s].append(f\"{et}->{node_display_name(t)}\")\n",
    "        evidence[t].append(f\"{et}<-{node_display_name(s)}\")\n",
    "    return {k: \"; \".join(v[:max_items]) for k, v in evidence.items()}\n",
    "\n",
    "edge_evidence_map = build_edge_evidence_map(edges_df)\n",
    "\n",
    "if len(recommend_df) > 0:\n",
    "    verification_df = recommend_df.copy()\n",
    "    verification_df[\"graph_evidence\"] = verification_df[\"message_node_id\"].map(edge_evidence_map).fillna(\"\")\n",
    "    verification_df[\"has_direct_graph_evidence\"] = verification_df[\"graph_evidence\"].str.len() > 0\n",
    "    verification_df[\"verification_status\"] = np.where(\n",
    "        verification_df[\"observed_in_original_graph\"],\n",
    "        \"OBSERVED_RELATION\",\n",
    "        np.where(\n",
    "            verification_df[\"confidence\"] >= verification_df.groupby(\"relation\")[\"confidence\"].transform(\"quantile\", 0.75),\n",
    "            \"HIGH_SCORE_NEW_CANDIDATE\",\n",
    "            \"REVIEW_CANDIDATE\"\n",
    "        )\n",
    "    )\n",
    "    display(verification_df.head(20))\n",
    "    print(\"verification_status 분포\")\n",
    "    display(verification_df[\"verification_status\"].value_counts())\n",
    "else:\n",
    "    verification_df = pd.DataFrame()\n",
    "\n",
    "verification_df.to_csv(\n",
    "    f\"{CONFIG['out_dir']}/gnn_relation_recommendation_verification.csv\",\n",
    "    index=False,\n",
    "    encoding=\"utf-8-sig\",\n",
    ")\n"
   ]
  },
