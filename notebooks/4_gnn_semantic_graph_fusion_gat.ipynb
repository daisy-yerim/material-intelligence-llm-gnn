    "def add_model_order_and_sort(df, sort_cols):\n",
    "    \"\"\"모델 표시 순서를 부여하고 지정 컬럼 기준으로 정렬합니다.\"\"\"\n",
    "    out = df.copy()\n",
    "    out[\"model_order\"] = out[\"model_key\"].map(MODEL_ORDER).fillna(99)\n",
    "    return (\n",
    "        out\n",
    "        .sort_values(sort_cols)\n",
    "        .drop(columns=[\"model_order\"])\n",
    "        .reset_index(drop=True)\n",
    "    )"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "def summarize_model_comparison(model_comparison_df):\n",
    "    \"\"\"seed별 비교 결과를 평균·표준편차 요약표로 집계합니다.\"\"\"\n",
    "    metric_cols = [\n",
    "        c for c in [\"auc\", \"ap\", \"mrr\", \"hits@1\", \"hits@3\", \"hits@5\", \"hits@10\"]\n",
    "        if c in model_comparison_df.columns\n",
    "    ]\n",
    "\n",
    "    agg_spec = {\n",
    "        \"num_seeds\": (\"seed\", \"nunique\"),\n",
    "        \"best_epoch_mean\": (\"best_epoch\", \"mean\"),\n",
    "        \"best_epoch_std\": (\"best_epoch\", \"std\"),\n",
    "        \"stopped_epoch_mean\": (\"stopped_epoch\", \"mean\"),\n",
    "        \"stopped_epoch_std\": (\"stopped_epoch\", \"std\"),\n",
    "        \"best_valid_score_mean\": (\"best_valid_score\", \"mean\"),\n",
    "        \"best_valid_score_std\": (\"best_valid_score\", \"std\"),\n",
    "    }\n",
    "\n",
    "    for c in metric_cols:\n",
    "        agg_spec[f\"{c}_mean\"] = (c, \"mean\")\n",
    "        agg_spec[f\"{c}_std\"] = (c, \"std\")\n",
    "\n",
    "    summary_df = (\n",
    "        model_comparison_df\n",
    "        .groupby([\"split\", \"model_key\", \"model\", \"model_group\"], as_index=False)\n",
    "        .agg(**agg_spec)\n",
    "    )\n",
    "\n",
    "    return add_model_order_and_sort(summary_df, sort_cols=[\"split\", \"model_order\"])"
   ]
  },
