    "def export_human_review_sample(verification_df, rule_validation_df=None):\n",
    "    if verification_df is None or len(verification_df) == 0:\n",
    "        print(\"verification_df가 비어 있어 사람 검수 샘플을 만들지 않습니다.\")\n",
    "        return pd.DataFrame()\n",
    "\n",
    "    base = verification_df.copy()\n",
    "    if rule_validation_df is not None and len(rule_validation_df) > 0:\n",
    "        key_cols = [\"message_node_id\", \"relation\", \"candidate_node_id\"]\n",
    "        add_cols = key_cols + [\"has_rule_match\", \"rule_match_count_top5\", \"matched_rule_preview\"]\n",
    "        base = base.merge(rule_validation_df[add_cols], on=key_cols, how=\"left\")\n",
    "    else:\n",
    "        base[\"has_rule_match\"] = False\n",
    "        base[\"rule_match_count_top5\"] = 0\n",
    "        base[\"matched_rule_preview\"] = \"\"\n",
    "\n",
    "    # 관계별/상태별로 너무 한쪽에 몰리지 않게 샘플링\n",
    "    sample_size = min(CONFIG.get(\"human_review_sample_size\", 200), len(base))\n",
    "    sampled = (\n",
    "        base.sort_values(\"confidence\", ascending=False)\n",
    "            .groupby([\"relation\", \"verification_status\"], group_keys=False)\n",
    "            .head(max(3, sample_size // max(1, base[[\"relation\", \"verification_status\"]].drop_duplicates().shape[0])))\n",
    "    )\n",
    "    if len(sampled) < sample_size:\n",
    "        remain = base.drop(index=sampled.index, errors=\"ignore\").sort_values(\"confidence\", ascending=False).head(sample_size - len(sampled))\n",
    "        sampled = pd.concat([sampled, remain], ignore_index=True)\n",
    "    sampled = sampled.head(sample_size).copy()\n",
    "    sampled[\"human_label\"] = \"\"  # 맞음 / 부분맞음 / 틀림\n",
    "    sampled[\"human_comment\"] = \"\"\n",
    "\n",
    "    keep_cols = [\n",
    "        \"message_id\", \"message_text\", \"source_domain\", \"date\", \"message_type\",\n",
    "        \"problem_type_context\", \"cluster_name_final_context\",\n",
    "        \"relation\", \"candidate_name\", \"score\", \"confidence\", \"observed_in_original_graph\",\n",
    "        \"verification_status\", \"has_rule_match\", \"matched_rule_preview\", \"graph_evidence\",\n",
    "        \"human_label\", \"human_comment\",\n",
    "    ]\n",
    "    keep_cols = [c for c in keep_cols if c in sampled.columns]\n",
    "    sampled = sampled[keep_cols]\n",
    "    sampled.to_csv(f\"{CONFIG['out_dir']}/human_review_sample.csv\", index=False, encoding=\"utf-8-sig\")\n",
    "    print(\"human review sample saved:\", f\"{CONFIG['out_dir']}/human_review_sample.csv\")\n",
    "    display(sampled.head(20))\n",
    "    return sampled"
   ]
  },
