    "def load_message_embeddings_if_available(message_df):\n",
    "    \"\"\"message 단위의 실제 semantic embedding을 로드합니다.\n",
    "\n",
    "    - message_df 안의 벡터 컬럼도 지원하지만, 기본적으로 1번에서 저장한 BGE-M3 npy를 우선 사용합니다.\n",
    "    - `embedding_row_idx`, `index`, `idx`처럼 인덱스성 컬럼은 embedding으로 사용하지 않습니다.\n",
    "    - require_external_message_embedding=True이면 embedding을 못 찾았을 때 중단합니다.\n",
    "    \"\"\"\n",
    "    min_dim = int(CONFIG.get(\"min_semantic_embedding_dim\", 128))\n",
    "\n",
    "    emb_path, checked = resolve_existing_path_from_candidates(CONFIG.get(\"external_embedding_candidates\", []))\n",
    "    if emb_path is not None:\n",
    "        mat = load_embedding_matrix(emb_path)\n",
    "        if mat.shape[1] < min_dim:\n",
    "            raise ValueError(f\"외부 임베딩 차원이 너무 작습니다: {mat.shape[1]} < {min_dim}, path={emb_path}\")\n",
    "        meta_df, meta_path = load_embedding_meta_if_available()\n",
    "        aligned, align_info = align_external_embeddings(message_df, mat, meta_df=meta_df)\n",
    "        return aligned.astype(np.float32), {\n",
    "            \"embedding_source\": \"external_bge_m3_file\",\n",
    "            \"embedding_col\": None,\n",
    "            \"embedding_path\": str(emb_path),\n",
    "            \"embedding_meta_path\": str(meta_path) if meta_path is not None else None,\n",
    "            **align_info,\n",
    "        }\n",
    "\n",
    "    # 외부 파일이 없으면 message_df 안의 진짜 벡터 컬럼을 찾습니다. 인덱스성 컬럼은 detect_embedding_col에서 제외됩니다.\n",
    "    emb_col = detect_embedding_col(message_df)\n",
    "    if emb_col is not None:\n",
    "        parsed = [parse_embedding(v) for v in message_df[emb_col].tolist()]\n",
    "        valid = [e for e in parsed if e is not None and len(e) > 0]\n",
    "        if len(valid) >= max(1, int(len(message_df) * CONFIG.get(\"min_message_embedding_match_ratio\", 0.90))):\n",
    "            dim = len(valid[0])\n",
    "            if dim >= min_dim:\n",
    "                mat = np.zeros((len(message_df), dim), dtype=np.float32)\n",
    "                for i, e in enumerate(parsed):\n",
    "                    if e is not None:\n",
    "                        mat[i, :min(dim, len(e))] = e[:dim]\n",
    "                return mat, {\n",
    "                    \"embedding_source\": \"message_df_vector_column\",\n",
    "                    \"embedding_col\": emb_col,\n",
    "                    \"embedding_path\": None,\n",
    "                    \"embedding_meta_path\": None,\n",
    "                    \"alignment_method\": \"message_df_row_order\",\n",
    "                    \"matched_rows\": int(len(valid)),\n",
    "                    \"match_ratio\": float(len(valid) / len(message_df)),\n",
    "                }\n",
    "\n",
    "    msg = \"\\n\".join([\n",
    "        \"BGE-M3 외부 임베딩 파일을 찾지 못했습니다.\",\n",
    "        \"1번 노트북을 먼저 실행해서 data/embeddings/message_embeddings_bge_m3_minimal.npy를 생성하세요.\",\n",
    "        \"또는 results/cluster_interpretation/에 message_embeddings.npy로 복사하세요.\",\n",
    "        \"확인한 경로 예시:\",\n",
    "        *checked[:20],\n",
    "    ])\n",
    "    if CONFIG.get(\"require_external_message_embedding\", True):\n",
    "        raise FileNotFoundError(msg)\n",
    "    print(\"[WARN]\", msg)\n",
    "    return None, {\"embedding_source\": None, \"embedding_col\": None, \"embedding_path\": None, \"embedding_meta_path\": None}"
   ]
