    "def sample_negative_triples(pos_triples, num_nodes, rel_tail_candidates, positive_set, negatives_per_positive=1, seed=None):\n",
    "    # tail corruption 중심의 type-aware negative sampling.\n",
    "    if len(pos_triples) == 0:\n",
    "        return torch.empty((0, 3), dtype=torch.long)\n",
    "\n",
    "    rng = np.random.default_rng(seed)\n",
    "    pos_np = pos_triples.detach().cpu().numpy()\n",
    "    neg = []\n",
    "\n",
    "    for s, r, t in pos_np:\n",
    "        candidates = rel_tail_candidates.get(int(r), list(range(num_nodes)))\n",
    "        if len(candidates) == 0:\n",
    "            candidates = list(range(num_nodes))\n",
    "\n",
    "        for _ in range(negatives_per_positive):\n",
    "            for _try in range(100):\n",
    "                nt = int(rng.choice(candidates))\n",
    "                cand = (int(s), int(r), nt)\n",
    "                if cand not in positive_set and nt != int(t):\n",
    "                    neg.append(cand)\n",
    "                    break\n",
    "            else:\n",
    "                # fallback\n",
    "                nt = int(rng.integers(0, num_nodes))\n",
    "                neg.append((int(s), int(r), nt))\n",
    "\n",
    "    return torch.tensor(neg, dtype=torch.long)\n",
    "\n",
    "def make_eval_negative_triples(pos_triples, seed=42):\n",
    "    return sample_negative_triples(\n",
    "        pos_triples,\n",
    "        num_nodes=len(node2idx),\n",
    "        rel_tail_candidates=rel_tail_candidates,\n",
    "        positive_set=positive_set,\n",
    "        negatives_per_positive=1,\n",
    "        seed=seed,\n",
    "    )\n",
    "\n",
    "valid_neg_triples = make_eval_negative_triples(valid_triples, seed=CONFIG[\"seed\"] + 101)\n",
    "test_neg_triples = make_eval_negative_triples(test_triples, seed=CONFIG[\"seed\"] + 202)\n",
    "\n",
    "print(\"valid neg:\", len(valid_neg_triples))\n",
    "print(\"test neg:\", len(test_neg_triples))\n"
   ]
  },
