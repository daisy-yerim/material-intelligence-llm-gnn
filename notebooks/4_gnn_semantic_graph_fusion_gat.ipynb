    "def select_final_model(summary_df, by_seed_df, config):\n",
    "    \"\"\"test 성능을 사용하지 않고 validation 기준으로 최종 모델을 선택합니다.\"\"\"\n",
    "    selection_split = config.get(\"model_selection_split\", \"valid\")\n",
    "    selection_metric = config.get(\"model_selection_metric\", \"mrr\")\n",
    "\n",
    "    if summary_df is not None and len(summary_df):\n",
    "        selected_info = select_model_from_summary(\n",
    "            summary_df,\n",
    "            by_seed_df,\n",
    "            selection_split,\n",
    "            selection_metric,\n",
    "        )\n",
    "        if selected_info:\n",
    "            return selected_info\n",
    "\n",
    "    if by_seed_df is not None and len(by_seed_df):\n",
    "        return select_model_from_by_seed(by_seed_df, selection_split, selection_metric)\n",
    "\n",
    "    return {}"
   ]
  },
