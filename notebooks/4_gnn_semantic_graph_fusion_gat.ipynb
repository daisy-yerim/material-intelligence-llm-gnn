    "def expanded_candidate_roots():\n",
    "    \"\"\"base_dir와 현재 작업 폴더 주변에서 1번 임베딩 파일을 찾기 위한 root 목록을 만듭니다.\"\"\"\n",
    "    roots = []\n",
    "    for base in CONFIG.get(\"base_dir_candidates\", [\".\"]):\n",
    "        p = Path(base).expanduser()\n",
    "        for q in [p, p.parent, p.parent.parent]:\n",
    "            if str(q) not in [str(x) for x in roots]:\n",
    "                roots.append(q)\n",
    "    for p in [Path(\".\"), Path(\"..\"), Path(\"../..\")]:\n",
    "        if str(p) not in [str(x) for x in roots]:\n",
    "            roots.append(p)\n",
    "    return roots"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "def resolve_existing_path_from_candidates(candidates):\n",
    "    checked = []\n",
    "    roots = expanded_candidate_roots()\n",
    "    for cand in candidates:\n",
    "        cp = Path(cand).expanduser()\n",
    "        if cp.is_absolute():\n",
    "            checked.append(str(cp))\n",
    "            if cp.exists():\n",
    "                return cp.resolve(), checked\n",
    "        else:\n",
    "            for root in roots:\n",
    "                path = (root / cp).expanduser()\n",
    "                checked.append(str(path))\n",
    "                if path.exists():\n",
    "                    return path.resolve(), checked\n",
    "    return None, checked"
   ]
  },
