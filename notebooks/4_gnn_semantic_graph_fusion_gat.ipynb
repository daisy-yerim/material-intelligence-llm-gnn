    "def create_training_components(model_i):\n",
    "    \"\"\"optimizer, scheduler, early stopping 설정을 생성합니다.\"\"\"\n",
    "    optimizer = torch.optim.AdamW(\n",
    "        model_i.parameters(),\n",
    "        lr=CONFIG[\"lr\"],\n",
    "        weight_decay=CONFIG[\"weight_decay\"],\n",
    "    )\n",
    "\n",
    "    scheduler = None\n",
    "    if CONFIG.get(\"use_lr_scheduler\", True):\n",
    "        scheduler = torch.optim.lr_scheduler.ReduceLROnPlateau(\n",
    "            optimizer,\n",
    "            mode=\"max\",\n",
    "            factor=float(CONFIG.get(\"lr_scheduler_factor\", 0.5)),\n",
    "            patience=int(CONFIG.get(\"lr_scheduler_patience\", 20)),\n",
    "        )\n",
    "\n",
    "    training_config = {\n",
    "        \"epochs\": int(CONFIG.get(\"model_comparison_epochs\", CONFIG[\"epochs\"])),\n",
    "        \"patience\": int(CONFIG.get(\"model_comparison_patience\", CONFIG[\"patience\"])),\n",
    "        \"eval_every\": int(CONFIG.get(\"model_comparison_eval_every\", 5)),\n",
    "        \"min_delta\": float(CONFIG.get(\"early_stopping_min_delta\", 1e-4)),\n",
    "    }\n",
    "    return optimizer, scheduler, training_config\n",
    "\n",
    "\n",
    "def sample_epoch_negative_triples(run_seed, epoch):\n",
    "    \"\"\"epoch별 train negative triples를 생성합니다.\"\"\"\n",
    "    return sample_negative_triples(\n",
    "        train_triples,\n",
    "        num_nodes=len(node2idx),\n",
    "        rel_tail_candidates=rel_tail_candidates,\n",
    "        positive_set=positive_set,\n",
    "        negatives_per_positive=CONFIG[\"negatives_per_positive\"],\n",
    "        seed=run_seed + 17000 + epoch,\n",
    "    )\n",
    "\n",
    "\n",
    "def run_single_training_epoch(model_i, optimizer, run_seed, epoch):\n",
    "    \"\"\"한 epoch의 forward/backward/update를 수행합니다.\"\"\"\n",
    "    model_i.train()\n",
    "    optimizer.zero_grad()\n",
    "\n",
    "    neg_triples_i = sample_epoch_negative_triples(run_seed, epoch)\n",
    "    pos_scores_i, _ = model_i(\n",
    "        x_device,\n",
    "        edge_index_device,\n",
    "        edge_type_device,\n",
    "        train_triples.to(device),\n",
    "    )\n",
    "    neg_scores_i, _ = model_i(\n",
    "        x_device,\n",
    "        edge_index_device,\n",
    "        edge_type_device,\n",
    "        neg_triples_i.to(device),\n",
    "    )\n",
    "\n",
    "    loss_i, bce_i, rank_i = compute_link_prediction_loss_for_scores(\n",
    "        pos_scores_i,\n",
    "        neg_scores_i,\n",
    "    )\n",
    "\n",
    "    loss_i.backward()\n",
    "    torch.nn.utils.clip_grad_norm_(model_i.parameters(), max_norm=5.0)\n",
    "    optimizer.step()\n",
    "    return loss_i, bce_i, rank_i\n",
    "\n",
    "\n",
    "def evaluate_validation_for_training(model_i, valid_rank_seed):\n",
    "    \"\"\"early stopping에 사용할 validation 지표를 계산합니다.\"\"\"\n",
    "    valid_bin_i = evaluate_binary(\n",
    "        model_i,\n",
    "        x,\n",
    "        edge_index,\n",
    "        edge_type,\n",
    "        valid_triples,\n",
    "        valid_neg_triples,\n",
    "        device,\n",
    "    )\n",
    "    valid_rank_i = evaluate_ranking(\n",
    "        model_i,\n",
    "        x,\n",
    "        edge_index,\n",
    "        edge_type,\n",
    "        valid_triples,\n",
    "        rel_tail_candidates,\n",
    "        positive_set,\n",
    "        device,\n",
    "        num_candidates=CONFIG[\"rank_num_candidates\"],\n",
    "        hits_ks=CONFIG[\"hits_ks\"],\n",
    "        seed=valid_rank_seed,\n",
    "    )\n",
    "    valid_score_i = select_early_stopping_score(valid_bin_i, valid_rank_i)\n",
    "    return valid_bin_i, valid_rank_i, valid_score_i\n",
    "\n",
    "\n",
    "def build_training_history_row(\n",
    "    run_seed,\n",
    "    model_key,\n",
    "    epoch,\n",
    "    loss_i,\n",
    "    bce_i,\n",
    "    rank_i,\n",
    "    current_lr,\n",
    "    valid_score_i,\n",
    "    best_score_i,\n",
    "    patience_counter_i,\n",
    "    valid_bin_i,\n",
    "    valid_rank_i,\n",
    "):\n",
    "    \"\"\"모델 비교 학습 이력을 한 행으로 구성합니다.\"\"\"\n",
    "    return {\n",
    "        \"seed\": run_seed,\n",
    "        \"model_key\": model_key,\n",
    "        \"model\": model_display_name(model_key),\n",
    "        \"model_group\": model_group_name(model_key),\n",
    "        \"epoch\": epoch,\n",
    "        \"loss\": float(loss_i.item()),\n",
    "        \"bce_loss\": float(bce_i.item()),\n",
    "        \"rank_loss\": float(rank_i.item()),\n",
    "        \"lr\": float(current_lr),\n",
    "        \"early_stopping_metric\": CONFIG.get(\"early_stopping_metric\", \"mrr\"),\n",
    "        \"early_stopping_score\": float(valid_score_i),\n",
    "        \"best_score_so_far\": float(max(best_score_i, valid_score_i)),\n",
    "        \"patience_counter\": int(patience_counter_i),\n",
    "        **{f\"valid_{k}\": v for k, v in valid_bin_i.items()},\n",
    "        **{f\"valid_{k}\": v for k, v in valid_rank_i.items()},\n",
    "    }\n",
    "\n",
    "\n",
    "def snapshot_model_state(model_i, epoch, valid_score_i):\n",
    "    \"\"\"현재 모델 상태를 CPU tensor 기반 snapshot으로 저장합니다.\"\"\"\n",
    "    return {\n",
    "        \"epoch\": epoch,\n",
    "        \"valid_score\": float(valid_score_i),\n",
    "        \"model_state\": {\n",
    "            k: v.detach().cpu().clone()\n",
    "            for k, v in model_i.state_dict().items()\n",
    "        },\n",
    "    }\n",
    "\n",
    "\n",
    "def print_training_progress(\n",
    "    model_key,\n",
    "    run_seed,\n",
    "    epoch,\n",
    "    loss_i,\n",
    "    valid_rank_i,\n",
    "    valid_bin_i,\n",
    "    best_score_i,\n",
    "    patience_counter_i,\n",
    "    patience,\n",
    "    current_lr,\n",
    "):\n",
    "    \"\"\"모델 비교 실험의 중간 진행 상황을 출력합니다.\"\"\"\n",
    "    print(\n",
    "        f\"[{model_display_name(model_key)} | seed={run_seed}] \"\n",
    "        f\"epoch={epoch:03d} \"\n",
    "        f\"loss={loss_i.item():.4f} \"\n",
    "        f\"valid_mrr={valid_rank_i.get('mrr', np.nan):.4f} \"\n",
    "        f\"valid_auc={valid_bin_i.get('auc', np.nan):.4f} \"\n",
    "        f\"best_valid_score={best_score_i:.4f} \"\n",
    "        f\"patience={patience_counter_i}/{patience} \"\n",
    "        f\"lr={current_lr:.2e}\"\n",
    "    )\n",
    "\n",
    "\n",
    "def evaluate_final_split(model_i, split_name, rank_seed):\n",
    "    \"\"\"선택된 checkpoint의 valid/test 최종 성능을 계산합니다.\"\"\"\n",
    "    if split_name == \"valid\":\n",
    "        pos_triples = valid_triples\n",
    "        neg_triples = valid_neg_triples\n",
    "    elif split_name == \"test\":\n",
    "        pos_triples = test_triples\n",
    "        neg_triples = test_neg_triples\n",
    "    else:\n",
    "        raise ValueError(f\"지원하지 않는 split입니다: {split_name}\")\n",
    "\n",
    "    binary_metrics = evaluate_binary(\n",
    "        model_i,\n",
    "        x,\n",
    "        edge_index,\n",
    "        edge_type,\n",
    "        pos_triples,\n",
    "        neg_triples,\n",
    "        device,\n",
    "    )\n",
    "    ranking_metrics = evaluate_ranking(\n",
    "        model_i,\n",
    "        x,\n",
    "        edge_index,\n",
    "        edge_type,\n",
    "        pos_triples,\n",
    "        rel_tail_candidates,\n",
    "        positive_set,\n",
    "        device,\n",
    "        num_candidates=CONFIG[\"rank_num_candidates\"],\n",
    "        hits_ks=CONFIG[\"hits_ks\"],\n",
    "        seed=rank_seed,\n",
    "    )\n",
    "    return binary_metrics, ranking_metrics\n",
    "\n",
    "\n",
    "def build_final_metric_rows(\n",
    "    model_key,\n",
    "    run_seed,\n",
    "    best_state_i,\n",
    "    stopped_epoch_i,\n",
    "    stop_reason_i,\n",
    "    valid_metrics,\n",
    "    test_metrics,\n",
    "):\n",
    "    \"\"\"valid/test 최종 평가 결과를 모델 비교표 형식으로 변환합니다.\"\"\"\n",
    "    common_info = {\n",
    "        \"seed\": run_seed,\n",
    "        \"model_key\": model_key,\n",
    "        \"model\": model_display_name(model_key),\n",
    "        \"model_group\": model_group_name(model_key),\n",
    "        \"best_epoch\": best_state_i[\"epoch\"],\n",
    "        \"stopped_epoch\": stopped_epoch_i,\n",
    "        \"stop_reason\": stop_reason_i,\n",
    "        \"best_valid_score\": best_state_i[\"valid_score\"],\n",
    "        \"early_stopping_metric\": CONFIG.get(\"early_stopping_metric\", \"mrr\"),\n",
    "    }\n",
    "\n",
    "    valid_bin_i, valid_rank_i = valid_metrics\n",
    "    test_bin_i, test_rank_i = test_metrics\n",
    "\n",
    "    return [\n",
    "        {\n",
    "            \"split\": \"valid\",\n",
    "            **common_info,\n",
    "            **valid_bin_i,\n",
    "            **valid_rank_i,\n",
    "        },\n",
    "        {\n",
    "            \"split\": \"test\",\n",
    "            **common_info,\n",
    "            **test_bin_i,\n",
    "            **test_rank_i,\n",
    "        },\n",
    "    ]"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "def train_one_link_predictor(model_type, run_seed=None, verbose=False):\n",
    "    \"\"\"단일 모델/seed 조합에 대해 학습, early stopping, 최종 평가를 수행합니다.\"\"\"\n",
    "    model_key = canonical_model_key(model_type)\n",
    "\n",
    "    if run_seed is None:\n",
    "        run_seed = int(CONFIG[\"seed\"])\n",
    "\n",
    "    set_seed(run_seed)\n",
    "    model_i = build_model_by_type(model_key).to(device)\n",
    "    optimizer, scheduler, training_config = create_training_components(model_i)\n",
    "\n",
    "    epochs = training_config[\"epochs\"]\n",
    "    patience = training_config[\"patience\"]\n",
    "    eval_every = training_config[\"eval_every\"]\n",
    "    min_delta = training_config[\"min_delta\"]\n",
    "\n",
    "    best_state_i = None\n",
    "    best_score_i = -np.inf\n",
    "    patience_counter_i = 0\n",
    "    stopped_epoch_i = epochs\n",
    "    stop_reason_i = \"max_epoch\"\n",
    "    hist_rows = []\n",
    "\n",
    "    # validation ranking 후보는 epoch마다 바꾸지 않습니다.\n",
    "    # 그래야 early stopping 기준이 ranking sample noise에 흔들리지 않습니다.\n",
    "    valid_rank_seed = run_seed + 18000\n",
    "    test_rank_seed = run_seed + 19002\n",
    "\n",
    "    for epoch in range(1, epochs + 1):\n",
    "        loss_i, bce_i, rank_i = run_single_training_epoch(\n",
    "            model_i,\n",
    "            optimizer,\n",
    "            run_seed,\n",
    "            epoch,\n",
    "        )\n",
    "\n",
    "        if epoch != 1 and epoch % eval_every != 0:\n",
    "            continue\n",
    "\n",
    "        valid_bin_i, valid_rank_i, valid_score_i = evaluate_validation_for_training(\n",
    "            model_i,\n",
    "            valid_rank_seed,\n",
    "        )\n",
    "\n",
    "        if scheduler is not None:\n",
    "            scheduler.step(valid_score_i)\n",
    "\n",
    "        current_lr = optimizer.param_groups[0][\"lr\"]\n",
    "        hist_rows.append(\n",
    "            build_training_history_row(\n",
    "                run_seed,\n",
    "                model_key,\n",
    "                epoch,\n",
    "                loss_i,\n",
    "                bce_i,\n",
    "                rank_i,\n",
    "                current_lr,\n",
    "                valid_score_i,\n",
    "                best_score_i,\n",
    "                patience_counter_i,\n",
    "                valid_bin_i,\n",
    "                valid_rank_i,\n",
    "            )\n",
    "        )\n",
    "\n",
    "        improved = valid_score_i > best_score_i + min_delta\n",
    "        if improved:\n",
    "            best_score_i = valid_score_i\n",
    "            best_state_i = snapshot_model_state(model_i, epoch, valid_score_i)\n",
    "            patience_counter_i = 0\n",
    "        else:\n",
    "            patience_counter_i += eval_every\n",
    "\n",
    "        if verbose and (epoch == 1 or epoch % 20 == 0):\n",
    "            print_training_progress(\n",
    "                model_key,\n",
    "                run_seed,\n",
    "                epoch,\n",
    "                loss_i,\n",
    "                valid_rank_i,\n",
    "                valid_bin_i,\n",
    "                best_score_i,\n",
    "                patience_counter_i,\n",
    "                patience,\n",
    "                current_lr,\n",
    "            )\n",
    "\n",
    "        if patience_counter_i >= patience:\n",
    "            stopped_epoch_i = epoch\n",
    "            stop_reason_i = \"early_stopping\"\n",
    "            if verbose:\n",
    "                print(\n",
    "                    f\"[{model_display_name(model_key)} | seed={run_seed}] \"\n",
    "                    f\"early stopping at epoch {epoch} | \"\n",
    "                    f\"best_epoch={best_state_i['epoch']} | \"\n",
    "                    f\"best_valid_score={best_score_i:.4f}\"\n",
    "                )\n",
    "            break\n",
    "\n",
    "    if best_state_i is None:\n",
    "        raise RuntimeError(f\"{model_key}: best_state 생성 실패\")\n",
    "\n",
    "    model_i.load_state_dict(best_state_i[\"model_state\"])\n",
    "    model_i.to(device)\n",
    "\n",
    "    valid_metrics = evaluate_final_split(model_i, \"valid\", valid_rank_seed)\n",
    "    test_metrics = evaluate_final_split(model_i, \"test\", test_rank_seed)\n",
    "    rows = build_final_metric_rows(\n",
    "        model_key,\n",
    "        run_seed,\n",
    "        best_state_i,\n",
    "        stopped_epoch_i,\n",
    "        stop_reason_i,\n",
    "        valid_metrics,\n",
    "        test_metrics,\n",
    "    )\n",
    "\n",
    "    return model_i, pd.DataFrame(rows), pd.DataFrame(hist_rows)"
   ]
  },
