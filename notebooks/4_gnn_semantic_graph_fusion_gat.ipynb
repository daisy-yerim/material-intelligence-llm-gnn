    "## 5-1. 보조 기준선 비교\n",
    "\n",
    "아래 기준선은 메인 모델 성능표의 주인공이 아니라, 태스크 난이도와 데이터 특성을 확인하기 위한 **보조 기준선**입니다.\n",
    "\n",
    "- **Popularity baseline**: train relation에서 자주 등장한 tail node를 우선 추천\n",
    "- **TF-IDF text similarity baseline**: source node text와 target node text의 cosine similarity로 추천\n",
    "\n",
    "최종 모델 비교표에서는 이 기준선을 분리하고, GNN 계열 모델과 `SemanticGraphFusionGAT`를 중심으로 비교합니다."
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "def evaluate_popularity_baseline(pos_triples, train_triples, rel_tail_candidates, positive_set, num_candidates=100, hits_ks=(1,3,5,10), seed=42):\n",
    "    if len(pos_triples) == 0:\n",
    "        return {\"mrr\": np.nan, **{f\"hits@{k}\": np.nan for k in hits_ks}}\n",
    "    rng = np.random.default_rng(seed)\n",
    "    train_np = train_triples.detach().cpu().numpy()\n",
    "    tail_freq = defaultdict(Counter)\n",
    "    for s, r, t in train_np:\n",
    "        tail_freq[int(r)][int(t)] += 1\n",
    "\n",
    "    reciprocal_ranks = []\n",
    "    hits = {k: [] for k in hits_ks}\n",
    "    for s, r, t in pos_triples.detach().cpu().numpy():\n",
    "        candidates = list(rel_tail_candidates.get(int(r), []))\n",
    "        rng.shuffle(candidates)\n",
    "        sampled = [int(t)]\n",
    "        for cand_t in candidates:\n",
    "            cand_t = int(cand_t)\n",
    "            if cand_t == int(t):\n",
    "                continue\n",
    "            if (int(s), int(r), cand_t) in positive_set:\n",
    "                continue\n",
    "            sampled.append(cand_t)\n",
    "            if len(sampled) >= num_candidates:\n",
    "                break\n",
    "        if len(sampled) <= 1:\n",
    "            continue\n",
    "        scores = np.array([tail_freq[int(r)].get(ct, 0) for ct in sampled], dtype=float)\n",
    "        # 동점이면 작은 noise를 줘서 rank가 고정적으로 왜곡되지 않게 함\n",
    "        scores += rng.normal(0, 1e-9, size=len(scores))\n",
    "        true_score = scores[0]\n",
    "        rank = 1 + int(np.sum(scores[1:] > true_score))\n",
    "        reciprocal_ranks.append(1.0 / rank)\n",
    "        for k in hits_ks:\n",
    "            hits[k].append(1.0 if rank <= k else 0.0)\n",
    "    result = {\"mrr\": float(np.mean(reciprocal_ranks)) if reciprocal_ranks else np.nan}\n",
    "    for k in hits_ks:\n",
    "        result[f\"hits@{k}\"] = float(np.mean(hits[k])) if hits[k] else np.nan\n",
    "    return result"
   ]
  },
