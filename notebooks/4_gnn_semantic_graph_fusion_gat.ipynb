    "class RelationAwareGATLinkPredictor(nn.Module):\n",
    "    \"\"\"Relation-aware attention GNN for link prediction.\n",
    "\n",
    "    GATv2Conv 자체는 relation별 weight matrix를 따로 갖는 R-GCN과 다릅니다.\n",
    "    대신 relation type embedding을 edge_attr로 투입해서, attention 계산이\n",
    "    연결 관계의 의미를 반영하도록 구성했습니다.\n",
    "    \"\"\"\n",
    "    def __init__(\n",
    "        self,\n",
    "        in_dim,\n",
    "        hidden_dim,\n",
    "        out_dim,\n",
    "        num_relations_for_mp,\n",
    "        num_base_relations,\n",
    "        heads=4,\n",
    "        dropout=0.25,\n",
    "        attention_dropout=0.20,\n",
    "    ):\n",
    "        super().__init__()\n",
    "        if GATv2Conv is None:\n",
    "            raise ImportError(\"torch_geometric.nn.GATv2Conv를 사용할 수 없습니다. torch-geometric 버전을 확인하세요.\")\n",
    "        if hidden_dim % heads != 0:\n",
    "            raise ValueError(f\"hidden_dim({hidden_dim})은 attention_heads({heads})로 나누어떨어져야 합니다.\")\n",
    "        if out_dim % heads != 0:\n",
    "            raise ValueError(f\"out_dim({out_dim})은 attention_heads({heads})로 나누어떨어져야 합니다.\")\n",
    "\n",
    "        self.model_name = \"relation_attention_gat\"\n",
    "        self.input_proj = nn.Linear(in_dim, hidden_dim)\n",
    "        self.edge_emb1 = nn.Embedding(num_relations_for_mp, hidden_dim)\n",
    "        self.edge_emb2 = nn.Embedding(num_relations_for_mp, hidden_dim)\n",
    "\n",
    "        self.gat1 = GATv2Conv(\n",
    "            in_channels=hidden_dim,\n",
    "            out_channels=hidden_dim // heads,\n",
    "            heads=heads,\n",
    "            concat=True,\n",
    "            dropout=attention_dropout,\n",
    "            edge_dim=hidden_dim,\n",
    "            add_self_loops=False,\n",
    "        )\n",
    "        self.gat2 = GATv2Conv(\n",
    "            in_channels=hidden_dim,\n",
    "            out_channels=out_dim // heads,\n",
    "            heads=heads,\n",
    "            concat=True,\n",
    "            dropout=attention_dropout,\n",
    "            edge_dim=hidden_dim,\n",
    "            add_self_loops=False,\n",
    "        )\n",
    "\n",
    "        self.norm1 = nn.LayerNorm(hidden_dim)\n",
    "        self.norm2 = nn.LayerNorm(out_dim)\n",
    "        self.skip2 = nn.Linear(hidden_dim, out_dim)\n",
    "        self.rel_emb = nn.Embedding(num_base_relations, out_dim)\n",
    "        self.dropout = dropout\n",
    "        self.heads = heads\n",
    "        self.reset_parameters()\n",
    "\n",
    "    def reset_parameters(self):\n",
    "        nn.init.xavier_uniform_(self.input_proj.weight)\n",
    "        nn.init.zeros_(self.input_proj.bias)\n",
    "        nn.init.xavier_uniform_(self.edge_emb1.weight)\n",
    "        nn.init.xavier_uniform_(self.edge_emb2.weight)\n",
    "        nn.init.xavier_uniform_(self.rel_emb.weight)\n",
    "        nn.init.xavier_uniform_(self.skip2.weight)\n",
    "        nn.init.zeros_(self.skip2.bias)\n",
    "\n",
    "    def encode(self, x, edge_index, edge_type):\n",
    "        h0 = self.input_proj(x)\n",
    "        h0 = F.relu(h0)\n",
    "        h0 = F.dropout(h0, p=self.dropout, training=self.training)\n",
    "\n",
    "        e1 = self.edge_emb1(edge_type)\n",
    "        h1 = self.gat1(h0, edge_index, edge_attr=e1)\n",
    "        h1 = self.norm1(h1 + h0)\n",
    "        h1 = F.relu(h1)\n",
    "        h1 = F.dropout(h1, p=self.dropout, training=self.training)\n",
    "\n",
    "        e2 = self.edge_emb2(edge_type)\n",
    "        z = self.gat2(h1, edge_index, edge_attr=e2)\n",
    "        z = self.norm2(z + self.skip2(h1))\n",
    "        return z\n",
    "\n",
    "    @torch.no_grad()\n",
    "    def encode_with_attention(self, x, edge_index, edge_type):\n",
    "        \"\"\"최종 embedding과 layer별 attention weight를 함께 반환합니다.\"\"\"\n",
    "        self.eval()\n",
    "        h0 = self.input_proj(x)\n",
    "        h0 = F.relu(h0)\n",
    "\n",
    "        e1 = self.edge_emb1(edge_type)\n",
    "        h1, attn1 = self.gat1(h0, edge_index, edge_attr=e1, return_attention_weights=True)\n",
    "        h1 = self.norm1(h1 + h0)\n",
    "        h1 = F.relu(h1)\n",
    "\n",
    "        e2 = self.edge_emb2(edge_type)\n",
    "        z, attn2 = self.gat2(h1, edge_index, edge_attr=e2, return_attention_weights=True)\n",
    "        z = self.norm2(z + self.skip2(h1))\n",
    "        return z, {\"layer1\": attn1, \"layer2\": attn2}\n",
    "\n",
    "    def score_triples(self, z, triples):\n",
    "        s = triples[:, 0]\n",
    "        r = triples[:, 1]\n",
    "        t = triples[:, 2]\n",
    "        return (z[s] * self.rel_emb(r) * z[t]).sum(dim=-1)\n",
    "\n",
    "    def forward(self, x, edge_index, edge_type, triples):\n",
    "        z = self.encode(x, edge_index, edge_type)\n",
    "        score = self.score_triples(z, triples)\n",
    "        return score, z"
   ]
  },
