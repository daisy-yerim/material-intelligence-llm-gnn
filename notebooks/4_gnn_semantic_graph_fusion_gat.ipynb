    "def align_external_embeddings(message_df, emb_mat, meta_df=None):\n",
    "    \"\"\"1번 BGE-M3 embedding을 현재 message_df 순서에 맞춥니다.\n",
    "\n",
    "    우선순위:\n",
    "    1. message_df와 embedding 행 수가 같으면 현재 순서 사용\n",
    "    2. message_df.embedding_row_idx가 있으면 해당 index로 정렬\n",
    "    3. meta.message_id와 message_df.message_id를 매칭\n",
    "    4. meta.text_hash와 message_df.text_hash를 매칭\n",
    "    \"\"\"\n",
    "    n_msg = len(message_df)\n",
    "    emb_mat = np.asarray(emb_mat, dtype=np.float32)\n",
    "    if emb_mat.ndim != 2:\n",
    "        raise ValueError(f\"embedding matrix는 2차원이어야 합니다. 현재 shape={emb_mat.shape}\")\n",
    "\n",
    "    # 1) 같은 행 수면 기본적으로 같은 순서라고 판단합니다.\n",
    "    if emb_mat.shape[0] == n_msg:\n",
    "        return emb_mat, {\"alignment_method\": \"same_row_order\", \"matched_rows\": int(n_msg), \"match_ratio\": 1.0}\n",
    "\n",
    "    # 2) embedding_row_idx 기준\n",
    "    row_idx_col = find_col(message_df, [\"embedding_row_idx\"], required=False)\n",
    "    if row_idx_col is not None:\n",
    "        idx = pd.to_numeric(message_df[row_idx_col], errors=\"coerce\")\n",
    "        valid = idx.notna() & (idx >= 0) & (idx < emb_mat.shape[0])\n",
    "        if valid.mean() >= CONFIG.get(\"min_message_embedding_match_ratio\", 0.90):\n",
    "            aligned = np.zeros((n_msg, emb_mat.shape[1]), dtype=np.float32)\n",
    "            aligned[valid.values] = emb_mat[idx[valid].astype(int).values]\n",
    "            return aligned, {\"alignment_method\": \"message_df.embedding_row_idx\", \"matched_rows\": int(valid.sum()), \"match_ratio\": float(valid.mean())}\n",
    "\n",
    "    if meta_df is not None:\n",
    "        # meta 안의 embedding_row_idx가 있으면 실제 embedding row를 지정하고, 없으면 meta 행 index를 row로 사용합니다.\n",
    "        meta = meta_df.copy().reset_index(drop=False).rename(columns={\"index\": \"_meta_row\"})\n",
    "        meta_idx_col = find_col(meta, [\"embedding_row_idx\"], required=False)\n",
    "        if meta_idx_col is None:\n",
    "            meta[\"_embedding_row\"] = meta[\"_meta_row\"].astype(int)\n",
    "        else:\n",
    "            meta[\"_embedding_row\"] = pd.to_numeric(meta[meta_idx_col], errors=\"coerce\")\n",
    "\n",
    "        # 3) message_id 기준\n",
    "        msg_id_col = find_col(message_df, [\"message_id\", \"id\", \"msg_id\"], required=False)\n",
    "        meta_msg_id_col = find_col(meta, [\"message_id\", \"id\", \"msg_id\"], required=False)\n",
    "        if msg_id_col is not None and meta_msg_id_col is not None:\n",
    "            tmp = message_df[[msg_id_col]].copy().reset_index().rename(columns={\"index\": \"_msg_row\"})\n",
    "            tmp[\"_key\"] = tmp[msg_id_col].astype(str)\n",
    "            meta2 = meta[[meta_msg_id_col, \"_embedding_row\"]].copy()\n",
    "            meta2[\"_key\"] = meta2[meta_msg_id_col].astype(str)\n",
    "            merged = tmp.merge(meta2[[\"_key\", \"_embedding_row\"]], on=\"_key\", how=\"left\")\n",
    "            idx = pd.to_numeric(merged[\"_embedding_row\"], errors=\"coerce\")\n",
    "            valid = idx.notna() & (idx >= 0) & (idx < emb_mat.shape[0])\n",
    "            if valid.mean() >= CONFIG.get(\"min_message_embedding_match_ratio\", 0.90):\n",
    "                aligned = np.zeros((n_msg, emb_mat.shape[1]), dtype=np.float32)\n",
    "                aligned[merged.loc[valid, \"_msg_row\"].astype(int).values] = emb_mat[idx[valid].astype(int).values]\n",
    "                return aligned, {\"alignment_method\": \"meta.message_id\", \"matched_rows\": int(valid.sum()), \"match_ratio\": float(valid.mean())}\n",
    "\n",
    "        # 4) text_hash 기준\n",
    "        msg_hash_col = find_col(message_df, [\"text_hash\"], required=False)\n",
    "        meta_hash_col = find_col(meta, [\"text_hash\"], required=False)\n",
    "        if msg_hash_col is not None and meta_hash_col is not None:\n",
    "            tmp = message_df[[msg_hash_col]].copy().reset_index().rename(columns={\"index\": \"_msg_row\"})\n",
    "            tmp[\"_key\"] = tmp[msg_hash_col].astype(str)\n",
    "            meta2 = meta[[meta_hash_col, \"_embedding_row\"]].copy()\n",
    "            meta2[\"_key\"] = meta2[meta_hash_col].astype(str)\n",
    "            merged = tmp.merge(meta2[[\"_key\", \"_embedding_row\"]], on=\"_key\", how=\"left\")\n",
    "            idx = pd.to_numeric(merged[\"_embedding_row\"], errors=\"coerce\")\n",
    "            valid = idx.notna() & (idx >= 0) & (idx < emb_mat.shape[0])\n",
    "            if valid.mean() >= CONFIG.get(\"min_message_embedding_match_ratio\", 0.90):\n",
    "                aligned = np.zeros((n_msg, emb_mat.shape[1]), dtype=np.float32)\n",
    "                aligned[merged.loc[valid, \"_msg_row\"].astype(int).values] = emb_mat[idx[valid].astype(int).values]\n",
    "                return aligned, {\"alignment_method\": \"meta.text_hash\", \"matched_rows\": int(valid.sum()), \"match_ratio\": float(valid.mean())}\n",
    "\n",
    "    raise ValueError(\n",
    "        \"BGE-M3 embedding을 현재 message_df와 정렬하지 못했습니다.\\n\"\n",
    "        f\"embedding shape={emb_mat.shape}, message_df rows={n_msg}\\n\"\n",
    "        \"확인 사항: 1번 노트북의 message_master_minimal.csv와 3번의 message_with_cluster_name.csv가 같은 message_id/행 순서를 유지하는지 확인하세요.\"\n",
