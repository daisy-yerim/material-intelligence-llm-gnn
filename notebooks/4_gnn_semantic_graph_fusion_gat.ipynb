    "@torch.no_grad()\n",
    "def evaluate_binary(model, x, edge_index, edge_type, pos_triples, neg_triples, device):\n",
    "    if len(pos_triples) == 0 or len(neg_triples) == 0:\n",
    "        return {\"auc\": np.nan, \"ap\": np.nan, \"pos_mean_score\": np.nan, \"neg_mean_score\": np.nan}\n",
    "\n",
    "    model.eval()\n",
    "    z = model.encode(x.to(device), edge_index.to(device), edge_type.to(device))\n",
    "    pos_scores = model.score_triples(z, pos_triples.to(device)).detach().cpu().numpy()\n",
    "    neg_scores = model.score_triples(z, neg_triples.to(device)).detach().cpu().numpy()\n",
    "\n",
    "    y_true = np.concatenate([np.ones_like(pos_scores), np.zeros_like(neg_scores)])\n",
    "    y_score = np.concatenate([pos_scores, neg_scores])\n",
    "\n",
    "    try:\n",
    "        auc = roc_auc_score(y_true, y_score)\n",
    "    except Exception:\n",
    "        auc = np.nan\n",
    "    try:\n",
    "        ap = average_precision_score(y_true, y_score)\n",
    "    except Exception:\n",
    "        ap = np.nan\n",
    "\n",
    "    return {\n",
    "        \"auc\": float(auc),\n",
    "        \"ap\": float(ap),\n",
    "        \"pos_mean_score\": float(np.mean(pos_scores)) if len(pos_scores) else np.nan,\n",
    "        \"neg_mean_score\": float(np.mean(neg_scores)) if len(neg_scores) else np.nan,\n",
    "    }"
   ]
