    "def build_message_node_mapping(nodes_df, message_df):\n",
    "    # message_df 행과 message node_id를 연결합니다.\n",
    "    node_id_col = find_col(nodes_df, [\"node_id\"])\n",
    "    node_ids = set(nodes_df[node_id_col].astype(str))\n",
    "\n",
    "    # 3번 노트북의 make_node_id와 동일한 규칙을 최대한 재현\n",
    "    def make_node_id(node_type, value):\n",
    "        import re\n",
    "        value = clean_text(value).replace(\" \", \"_\")\n",
    "        value = re.sub(r\"[^\\w가-힣\\-_\\.]\", \"\", value)\n",
    "        if value == \"\":\n",
    "            value = \"UNKNOWN\"\n",
    "        return f\"{node_type}:{value}\"\n",
    "\n",
    "    id_col = find_col(message_df, [\"message_id\", \"id\", \"msg_id\"], required=False)\n",
    "    row_col = find_col(message_df, [\"row_idx_in_source\", \"row_idx\", \"index\"], required=False)\n",
    "\n",
    "    message_node_ids = []\n",
    "    for i, row in message_df.iterrows():\n",
    "        candidates = []\n",
    "        if id_col is not None:\n",
    "            mid = row[id_col]\n",
    "            candidates.extend([\n",
    "                str(mid),\n",
    "                make_node_id(\"message\", mid),\n",
    "                f\"message:{mid}\",\n",
    "                f\"msg:{mid}\",\n",
    "            ])\n",
    "        if row_col is not None:\n",
    "            rid = row[row_col]\n",
    "            candidates.extend([\n",
    "                str(rid),\n",
    "                make_node_id(\"message\", rid),\n",
    "                f\"message:{rid}\",\n",
    "                f\"msg:{rid}\",\n",
    "            ])\n",
    "        candidates.extend([make_node_id(\"message\", i), f\"message:{i}\", f\"msg:{i}\"])\n",
    "\n",
    "        found = None\n",
    "        for cand in candidates:\n",
    "            if cand in node_ids:\n",
    "                found = cand\n",
    "                break\n",
    "        message_node_ids.append(found)\n",
    "\n",
    "    matched = sum(x is not None for x in message_node_ids)\n",
    "    print(f\"message_df ↔ message node 매칭: {matched} / {len(message_df)}\")\n",
    "    if matched < max(1, int(len(message_df) * 0.8)):\n",
    "        print(\"[WARN] message node 매칭률이 낮습니다. 3번 노트북의 message node_id 생성 규칙을 확인하세요.\")\n",
    "    return message_node_ids"
   ]
