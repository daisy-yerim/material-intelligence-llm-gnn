    "def build_index_maps(nodes_df, edges_df):\n",
    "    node_id_col = find_col(nodes_df, [\"node_id\"])\n",
    "    node_ids = nodes_df[node_id_col].astype(str).tolist()\n",
    "    node2idx = {nid: i for i, nid in enumerate(node_ids)}\n",
    "    idx2node = {i: nid for nid, i in node2idx.items()}\n",
    "\n",
    "    # 전체 train graph relation + target relation의 relation id를 통합합니다.\n",
    "    all_rels = sorted(set(edges_df[edge_type_col].astype(str)) | set(target_relations))\n",
    "    edge_type2idx = {r: i for i, r in enumerate(all_rels)}\n",
    "    idx2edge_type = {i: r for r, i in edge_type2idx.items()}\n",
    "    return node2idx, idx2node, edge_type2idx, idx2edge_type"
   ]
  },
