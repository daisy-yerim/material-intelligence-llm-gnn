    "def build_cpu_state_dict(model):\n",
    "    \"\"\"환경 의존성을 줄이기 위해 CPU tensor 기반 state_dict를 생성합니다.\"\"\"\n",
    "    model.eval()\n",
    "    return {\n",
    "        key: value.detach().cpu()\n",
    "        for key, value in model.state_dict().items()\n",
    "    }"
   ]
