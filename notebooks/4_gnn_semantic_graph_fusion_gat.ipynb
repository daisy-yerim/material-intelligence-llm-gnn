    "def parse_embedding(value):\n",
    "    if value is None:\n",
    "        return None\n",
    "    if isinstance(value, float) and np.isnan(value):\n",
    "        return None\n",
    "    if isinstance(value, list):\n",
    "        return np.array(value, dtype=np.float32)\n",
    "    if isinstance(value, np.ndarray):\n",
    "        return value.astype(np.float32)\n",
    "\n",
    "    s = str(value).strip()\n",
    "    if len(s) == 0 or s.lower() in [\"nan\", \"none\", \"null\"]:\n",
    "        return None\n",
    "\n",
    "    try:\n",
    "        if s.startswith(\"[\") and s.endswith(\"]\"):\n",
    "            return np.array(ast.literal_eval(s), dtype=np.float32)\n",
    "    except Exception:\n",
    "        pass\n",
    "\n",
    "    try:\n",
    "        s2 = s.replace(\"\\n\", \" \").replace(\",\", \" \")\n",
    "        arr = np.fromstring(s2.strip(\"[]\"), sep=\" \", dtype=np.float32)\n",
    "        if arr.size > 0:\n",
    "            return arr\n",
    "    except Exception:\n",
    "        pass\n",
    "    return None"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "def detect_embedding_col(df):\n",
    "    \"\"\"의미 임베딩 컬럼을 찾습니다.\n",
    "\n",
    "    주의: 3번 노트북에서 생성된 `embedding_row_idx`는 실제 벡터가 아니라\n",
    "    message embedding 행 번호를 가리키는 인덱스일 수 있습니다. 이런 1차원 인덱스 컬럼은\n",
    "    semantic embedding으로 사용하면 성능이 크게 떨어지므로 제외합니다.\n",
    "    \"\"\"\n",
    "    blocked_keywords = [\"row_idx\", \"rowidx\", \"index\", \"idx\", \"id\"]\n",
    "    candidates = [\n",
    "        \"embedding\", \"embeddings\", \"text_embedding\", \"sentence_embedding\",\n",
    "        \"bge_embedding\", \"bge_m3_embedding\", \"llm_embedding\", \"gemma_embedding\",\n",
    "        \"vector\", \"2차 임베딩\", \"이차 임베딩\", \"임베딩\", \"embedding_2\", \"second_embedding\",\n",
    "    ]\n",
    "    for c in candidates:\n",
    "        if c in df.columns:\n",
    "            cl = str(c).lower().replace(\" \", \"\")\n",
    "            if any(b in cl for b in blocked_keywords):\n",
    "                continue\n",
    "            return c\n",
    "    for c in df.columns:\n",
    "        cl = str(c).lower().replace(\" \", \"\")\n",
    "        if any(b in cl for b in blocked_keywords):\n",
    "            continue\n",
    "        if \"embedding\" in cl or \"임베딩\" in str(c) or cl in [\"emb\", \"vector\"]:\n",
    "            return c\n",
    "    return None"
   ]
  },
