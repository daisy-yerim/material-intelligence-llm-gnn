    "def select_early_stopping_score(valid_bin_metrics, valid_rank_metrics):\n",
    "    metric_name = str(CONFIG.get(\"early_stopping_metric\", \"mrr\")).lower()\n",
    "\n",
    "    if metric_name in valid_rank_metrics:\n",
    "        score = valid_rank_metrics.get(metric_name, np.nan)\n",
    "    elif metric_name in valid_bin_metrics:\n",
    "        score = valid_bin_metrics.get(metric_name, np.nan)\n",
    "    elif \"mrr\" in valid_rank_metrics:\n",
    "        score = valid_rank_metrics.get(\"mrr\", np.nan)\n",
    "    else:\n",
    "        score = valid_bin_metrics.get(\"auc\", 0.0)\n",
    "\n",
    "    if np.isnan(score):\n",
    "        score = valid_bin_metrics.get(\"auc\", 0.0)\n",
    "\n",
    "    return score"
   ]
