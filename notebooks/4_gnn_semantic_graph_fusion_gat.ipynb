    "        candidates = list(rel_tail_candidates.get(int(r), range(x.shape[0])))\n",
    "        sampled = [int(t)]\n",
    "        if len(candidates) > 0:\n",
    "            rng.shuffle(candidates)\n",
    "            for cand_t in candidates:\n",
    "                cand_t = int(cand_t)\n",
    "                if cand_t == int(t):\n",
    "                    continue\n",
    "                if (int(s), int(r), cand_t) in positive_set:\n",
    "                    continue\n",
    "                sampled.append(cand_t)\n",
    "                if len(sampled) >= num_candidates:\n",
    "                    break\n",
    "        if len(sampled) <= 1:\n",
    "            continue\n",
    "\n",
    "        cand_triples = torch.tensor([[int(s), int(r), int(ct)] for ct in sampled], dtype=torch.long, device=device)\n",
    "        scores = model.score_triples(z, cand_triples).detach().cpu().numpy()\n",
    "        true_score = scores[0]\n",
    "        rank = 1 + int(np.sum(scores[1:] > true_score))\n",
    "        reciprocal_ranks.append(1.0 / rank)\n",
    "        for k in hits_ks:\n",
    "            hits[k].append(1.0 if rank <= k else 0.0)\n",
    "\n",
    "    if len(reciprocal_ranks) == 0:\n",
    "        return {\"mrr\": np.nan, **{f\"hits@{k}\": np.nan for k in hits_ks}}\n",
    "\n",
    "    result = {\"mrr\": float(np.mean(reciprocal_ranks))}\n",
    "    for k in hits_ks:\n",
    "        result[f\"hits@{k}\"] = float(np.mean(hits[k]))\n",
    "    return result"
   ]
  },
