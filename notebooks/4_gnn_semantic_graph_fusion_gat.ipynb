    "    return {\n",
    "        \"checkpoint_format\": \"material-intelligence-llm-gnn-final-model-v1\",\n",
    "        \"saved_at\": datetime.now().isoformat(timespec=\"seconds\"),\n",
    "        \"model_state_dict\": build_cpu_state_dict(model),\n",
