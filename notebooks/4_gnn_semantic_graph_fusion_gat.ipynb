    "def infer_node_type(node_id):\n",
    "    node_id = str(node_id)\n",
    "    if \":\" in node_id:\n",
    "        prefix = node_id.split(\":\", 1)[0]\n",
    "        if prefix == \"domain\":\n",
    "            return \"source_domain\"\n",
    "        return prefix\n",
    "\n",
    "    lowered = node_id.lower()\n",
    "    if lowered.startswith(\"message\") or lowered.startswith(\"msg\"):\n",
    "        return \"message\"\n",
    "    if lowered.startswith(\"cluster\"):\n",
    "        return \"cluster\"\n",
    "    if lowered.startswith(\"domain\") or lowered.startswith(\"source_domain\"):\n",
    "        return \"source_domain\"\n",
    "    if lowered.startswith(\"message_type\"):\n",
    "        return \"message_type\"\n",
    "    if lowered.startswith(\"part_no\"):\n",
    "        return \"part_no\"\n",
    "    if lowered.startswith(\"part_desc\"):\n",
    "        return \"part_desc\"\n",
    "    if lowered.startswith(\"org\"):\n",
    "        return \"org\"\n",
    "    if lowered.startswith(\"product\"):\n",
    "        return \"product\"\n",
    "    if lowered.startswith(\"date\"):\n",
