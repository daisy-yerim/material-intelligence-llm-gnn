    "def build_public_model_comparison_table(summary_df, by_seed_df, model_order):\n",
    "    \"\"\"보고서/공개 자료에 사용할 메인 모델 비교표를 생성합니다.\"\"\"\n",
    "    if summary_df is not None and len(summary_df):\n",
    "        comparison_df = summary_df[\n",
    "            summary_df[\"model_group\"].isin(PUBLIC_MODEL_GROUPS)\n",
    "        ].copy()\n",
    "        sort_cols = [\"split\", \"model_order\"]\n",
    "    elif by_seed_df is not None and len(by_seed_df):\n",
    "        comparison_df = by_seed_df[\n",
    "            by_seed_df[\"model_group\"].isin(PUBLIC_MODEL_GROUPS)\n",
    "        ].copy()\n",
    "        sort_cols = [\"split\", \"model_order\", \"seed\"]\n",
    "    else:\n",
    "        return pd.DataFrame()\n",
    "\n",
    "    if \"model_order\" not in comparison_df.columns:\n",
