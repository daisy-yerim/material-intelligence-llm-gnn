    "def resolve_first_existing(filenames, base_dir_candidates=None):\n",
    "    for fn in filenames:\n",
    "        p = resolve_data_path(fn, base_dir_candidates=base_dir_candidates, required=False)\n",
    "        if p is not None:\n",
    "            return p\n",
    "    return None"
   ]
