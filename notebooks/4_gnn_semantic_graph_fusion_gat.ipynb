    "def export_final_model_and_metadata():\n",
    "    selected_model_type, selected_model_label, selected_model_seed = get_selected_model_export_info(CONFIG)\n",
    "\n",
    "    out_dir = Path(CONFIG[\"out_dir\"])\n",
    "    out_dir.mkdir(parents=True, exist_ok=True)\n",
    "    MODEL_DIR.mkdir(parents=True, exist_ok=True)\n",
    "\n",
    "    paths = build_model_artifact_paths(selected_model_type, selected_model_seed, out_dir, MODEL_DIR)\n",
    "    checkpoint = build_checkpoint_payload(selected_model_type, selected_model_label, selected_model_seed)\n",
    "    save_checkpoint_files(checkpoint, paths)\n",
    "\n",
    "    metadata = build_experiment_metadata(selected_model_type, selected_model_label, selected_model_seed, paths)\n",
    "    save_metadata_files(metadata, out_dir, MODEL_DIR)\n",
    "    experiment_summary_df = save_experiment_summary(metadata, out_dir)\n",
    "\n",
    "    model_card_path = save_model_card(\n",
    "        MODEL_DIR,\n",
    "        selected_model_type,\n",
    "        selected_model_label,\n",
    "        selected_model_seed,\n",
    "        paths[\"model_artifact_name\"],\n",
    "    )\n",
    "\n",
    "    print(\"저장 완료:\", out_dir)\n",
    "    print(\"최종 모델:\", selected_model_label, f\"({selected_model_type}, seed={selected_model_seed})\")\n",
    "    print(\"최종 checkpoint:\", paths[\"final_model_path\"])\n",
    "    print(\"버전 checkpoint:\", paths[\"versioned_model_path\"])\n",
    "    print(\"결과 복사본:\", paths[\"results_model_path\"])\n",
    "    print(\"모델 카드:\", model_card_path)\n",
    "\n",
    "    return {\n",
    "        \"metadata\": metadata,\n",
    "        \"experiment_summary_df\": experiment_summary_df,\n",
    "        **paths,\n",
    "        \"model_card_path\": model_card_path,\n",
    "    }"
   ]
