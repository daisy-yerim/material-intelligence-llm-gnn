    "def export_grouped_model_comparison_tables(model_comparison_df, out_dir):\n",
    "    \"\"\"GNN 계열과 제안 모델 계열 결과표를 따로 저장합니다.\"\"\"\n",
    "    gnn_model_comparison_df = model_comparison_df[\n",
    "        model_comparison_df[\"model_group\"].eq(\"gnn_model\")\n",
    "    ].copy()\n",
    "\n",
    "    proposed_existing_metrics_df = model_comparison_df[\n",
    "        model_comparison_df[\"model_group\"].eq(\"proposed_existing_model\")\n",
    "    ].copy()\n",
    "\n",
    "    proposed_enhanced_metrics_df = model_comparison_df[\n",
    "        model_comparison_df[\"model_group\"].eq(\"proposed_enhanced_model\")\n",
    "    ].copy()\n",
    "\n",
    "    proposed_model_metrics_df = model_comparison_df[\n",
    "        model_comparison_df[\"model_group\"].isin([\n",
    "            \"proposed_existing_model\",\n",
    "            \"proposed_enhanced_model\",\n",
    "        ])\n",
    "    ].copy()\n",
    "\n",
    "    output_map = {\n",
    "        \"gnn_model_comparison_df\": (gnn_model_comparison_df, \"gnn_model_comparison_by_seed.csv\"),\n",
    "        \"proposed_existing_metrics_df\": (proposed_existing_metrics_df, \"proposed_sgf_gat_metrics_by_seed.csv\"),\n",
    "        \"proposed_enhanced_metrics_df\": (proposed_enhanced_metrics_df, \"proposed_e_sgf_gat_metrics_by_seed.csv\"),\n",
    "        \"proposed_model_metrics_df\": (proposed_model_metrics_df, \"proposed_models_comparison_by_seed.csv\"),\n",
    "    }\n",
    "\n",
    "    for _, (table, filename) in output_map.items():\n",
    "        table.to_csv(\n",
    "            f\"{out_dir}/{filename}\",\n",
    "            index=False,\n",
    "            encoding=\"utf-8-sig\",\n",
    "        )\n",
    "\n",
    "    return {name: table for name, (table, _) in output_map.items()}"
   ]
