    "        \"model_label\": selected_model_label,\n",
    "        \"selected_model_seed\": selected_model_seed,\n",
    "        \"model_selection_info\": make_json_serializable(CONFIG.get(\"model_selection_info\", {})),\n",
    "        \"config\": make_json_serializable(CONFIG),\n",
    "        \"feature_info\": make_json_serializable(feature_info),\n",
    "        \"node2idx\": make_json_serializable(node2idx),\n",
    "        \"idx2node\": make_json_serializable(idx2node),\n",
    "        \"edge_type2idx\": make_json_serializable(edge_type2idx),\n",
    "        \"idx2edge_type\": make_json_serializable(idx2edge_type),\n",
    "        \"num_relations_for_message_passing\": int(num_relations_for_mp),\n",
    "        \"in_dim\": int(x.shape[1]),\n",
    "        \"hidden_dim\": int(CONFIG[\"hidden_dim\"]),\n",
    "        \"out_dim\": int(CONFIG[\"out_dim\"]),\n",
    "        \"target_relations\": make_json_serializable(target_relations),\n",
    "        \"model_display_names\": make_json_serializable(MODEL_LABELS if \"MODEL_LABELS\" in globals() else {}),\n",
    "    }"
   ]
