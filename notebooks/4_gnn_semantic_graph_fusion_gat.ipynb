    "def _as_base_dirs(base_dir_candidates=None):\n",
    "    if base_dir_candidates is None:\n",
    "        base_dir_candidates = CONFIG.get(\"base_dir_candidates\", [\".\"])\n",
    "    if isinstance(base_dir_candidates, (str, Path)):\n",
    "        base_dir_candidates = [base_dir_candidates]\n",
    "    return [Path(p).expanduser() for p in base_dir_candidates]"
   ]
