   "source": [
    "def apply_selected_model_checkpoint(selected_info, comparison_models, config):\n",
    "    \"\"\"선택된 모델 객체를 downstream에서 사용할 기본 model로 지정합니다.\"\"\"\n",
    "    if not selected_info:\n",
    "        print(\"[WARN] 모델 비교 결과가 없어 자동 최종 모델 선택을 수행하지 못했습니다. 앞에서 학습한 기본 model을 그대로 사용합니다.\")\n",
    "        return globals().get(\"model\", None)\n",
    "\n",
    "    selected_model_key = selected_info[\"selected_model_key\"]\n",
    "    selected_seed = selected_info[\"selected_seed\"]\n",
    "\n",
    "    selected_model = comparison_models.get((selected_model_key, selected_seed))\n",
    "    if selected_model is None:\n",
    "        selected_model = comparison_models.get(selected_model_key)\n",
    "\n",
    "    if selected_model is None:\n",
    "        print(\"[WARN] 선택된 모델 checkpoint를 comparison_models에서 찾지 못했습니다. 앞에서 학습한 기본 model을 그대로 사용합니다.\")\n",
    "        return globals().get(\"model\", None)\n",
    "\n",
    "    config[\"model_type\"] = selected_model_key\n",
    "    config[\"selected_model_type\"] = selected_model_key\n",
    "    config[\"selected_model\"] = selected_info[\"selected_model\"]\n",
    "    config[\"selected_model_label\"] = selected_info[\"selected_model\"]\n",
    "    config[\"selected_model_seed\"] = selected_seed\n",
    "    config[\"model_selection_info\"] = selected_info\n",
    "\n",
    "    print(\n",
    "        \"[FINAL MODEL] \"\n",
    "        f\"{selected_info['selected_model']} \"\n",
    "        f\"(internal={selected_model_key}, seed={selected_seed}) \"\n",
    "        f\"selected by {selected_info['selection_split']}_{selected_info['selection_metric']}.\"\n",
    "    )\n",
    "    display(pd.DataFrame([selected_info]))\n",
    "    return selected_model"
   ]
