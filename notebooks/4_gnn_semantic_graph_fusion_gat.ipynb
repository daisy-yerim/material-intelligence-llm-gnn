    "def make_node_features(nodes_df, message_df, message_node_ids):\n",
    "    node_id_col = find_col(nodes_df, [\"node_id\"])\n",
    "    node_type_col = find_col(nodes_df, [\"node_type\", \"type\"], required=False)\n",
    "    node_types = nodes_df[node_type_col].fillna(\"unknown\").astype(str) if node_type_col else pd.Series([\"unknown\"] * len(nodes_df))\n",
    "\n",
    "    type_feat_df = pd.get_dummies(node_types, prefix=\"type\")\n",
    "    type_feat = type_feat_df.values.astype(np.float32)\n",
    "\n",
    "    node_texts, text_col = build_node_texts(nodes_df, message_df, message_node_ids)\n",
    "    message_emb, emb_info = load_message_embeddings_if_available(message_df)\n",
    "\n",
    "    if message_emb is not None:\n",
    "        if CONFIG.get(\"normalize_features\", True):\n",
    "            message_emb = l2_normalize_np(message_emb)\n",
    "        semantic_dim = int(message_emb.shape[1])\n",
    "        semantic_feat = np.zeros((len(nodes_df), semantic_dim), dtype=np.float32)\n",
    "        node_id_to_idx = {nid: i for i, nid in enumerate(nodes_df[node_id_col].astype(str))}\n",
    "        fill_count = 0\n",
    "        for row_i, node_id in enumerate(message_node_ids):\n",
    "            if node_id is not None and node_id in node_id_to_idx:\n",
    "                semantic_feat[node_id_to_idx[node_id], :] = message_emb[row_i]\n",
    "                fill_count += 1\n",
    "        print(f\"[INFO] BGE/semantic message embedding 사용: {emb_info.get('embedding_source')}, 채운 message node={fill_count}\")\n",
    "    else:\n",
    "        if not CONFIG.get(\"use_tfidf_svd_fallback\", False):\n",
    "            raise ValueError(\"semantic embedding을 찾지 못했고 TF-IDF fallback이 비활성화되어 있습니다.\")\n",
    "        print(\"[WARN] 디버그용 TF-IDF+SVD fallback을 사용합니다. 최종 제안서 실험 결과로는 사용하지 마세요.\")\n",
    "        semantic_feat, tmp_info = make_node_text_svd_features(node_texts)\n",
    "        semantic_dim = int(semantic_feat.shape[1])\n",
    "        emb_info.update({\"embedding_source\": \"tfidf_svd_fallback_all_node_text\", \"embedding_col\": text_col, \"embedding_path\": None, **tmp_info})\n",
    "\n",
    "    node_text_feat, node_text_info = make_node_text_svd_features(node_texts)\n",
    "\n",
    "    x_np = np.concatenate([type_feat, semantic_feat, node_text_feat], axis=1).astype(np.float32)\n",
    "    x = torch.tensor(x_np, dtype=torch.float32)\n",
    "    feature_info = {\n",
    "        **emb_info,\n",
    "        **node_text_info,\n",
    "        \"semantic_feature_dim\": int(semantic_dim),\n",
    "        \"node_type_feature_dim\": int(type_feat.shape[1]),\n",
    "        \"total_dim\": int(x.shape[1]),\n",
    "        \"node_type_columns\": list(type_feat_df.columns),\n",
    "        \"text_col\": text_col,\n",
    "        \"bge_message_nodes_filled\": int(fill_count) if message_emb is not None else 0,\n",
    "    }\n",
    "    return x, feature_info, node_texts\n",
    "\n",
    "message_node_ids = build_message_node_mapping(nodes_df, message_df)\n",
    "x, feature_info, node_texts = make_node_features(nodes_df, message_df, message_node_ids)\n",
    "\n",
    "print(\"x shape:\", tuple(x.shape))\n",
    "print(json.dumps(feature_info, indent=2, ensure_ascii=False))\n",
    "\n",
