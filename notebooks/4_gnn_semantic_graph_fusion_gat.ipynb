    "class GATv2LinkPredictor(nn.Module):\n",
    "    \"\"\"기본 attention GNN. relation type은 attention edge_attr로 쓰지 않음.\"\"\"\n",
    "    def __init__(self, in_dim, hidden_dim, out_dim, num_relations_for_mp, num_base_relations, heads=4, dropout=0.25, attention_dropout=0.20):\n",
    "        super().__init__()\n",
    "        if GATv2Conv is None:\n",
    "            raise ImportError(\"GATv2Conv를 사용할 수 없습니다. torch-geometric 버전을 확인하세요.\")\n",
    "        if hidden_dim % heads != 0 or out_dim % heads != 0:\n",
    "            raise ValueError(\"hidden_dim과 out_dim은 heads로 나누어떨어져야 합니다.\")\n",
    "        self.model_name = \"gatv2\"\n",
    "        self.input_proj = nn.Linear(in_dim, hidden_dim)\n",
    "        self.gat1 = GATv2Conv(hidden_dim, hidden_dim // heads, heads=heads, concat=True, dropout=attention_dropout, add_self_loops=False)\n",
    "        self.gat2 = GATv2Conv(hidden_dim, out_dim // heads, heads=heads, concat=True, dropout=attention_dropout, add_self_loops=False)\n",
    "        self.norm1 = nn.LayerNorm(hidden_dim)\n",
    "        self.norm2 = nn.LayerNorm(out_dim)\n",
    "        self.skip2 = nn.Linear(hidden_dim, out_dim)\n",
    "        self.rel_emb = nn.Embedding(num_base_relations, out_dim)\n",
    "        self.dropout = dropout\n",
    "        self.reset_parameters()\n",
    "\n",
    "    def reset_parameters(self):\n",
    "        nn.init.xavier_uniform_(self.input_proj.weight)\n",
    "        nn.init.zeros_(self.input_proj.bias)\n",
    "        nn.init.xavier_uniform_(self.skip2.weight)\n",
    "        nn.init.zeros_(self.skip2.bias)\n",
    "        nn.init.xavier_uniform_(self.rel_emb.weight)\n",
    "\n",
    "    def encode(self, x, edge_index, edge_type=None):\n",
    "        h0 = F.relu(self.input_proj(x))\n",
    "        h0 = F.dropout(h0, p=self.dropout, training=self.training)\n",
    "        h1 = self.gat1(h0, edge_index)\n",
    "        h1 = self.norm1(h1 + h0)\n",
    "        h1 = F.relu(h1)\n",
    "        h1 = F.dropout(h1, p=self.dropout, training=self.training)\n",
    "        z = self.gat2(h1, edge_index)\n",
    "        z = self.norm2(z + self.skip2(h1))\n",
    "        return z\n",
    "\n",
    "    def score_triples(self, z, triples):\n",
    "        s, r, t = triples[:, 0], triples[:, 1], triples[:, 2]\n",
    "        return (z[s] * self.rel_emb(r) * z[t]).sum(dim=-1)\n",
    "\n",
    "    def forward(self, x, edge_index, edge_type, triples):\n",
    "        z = self.encode(x, edge_index, edge_type)\n",
    "        return self.score_triples(z, triples), z"
   ]
  },
