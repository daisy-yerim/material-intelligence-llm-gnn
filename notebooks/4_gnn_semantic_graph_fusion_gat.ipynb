    "def build_experiment_summary(metadata):\n",
    "    \"\"\"사람이 빠르게 검토할 수 있는 실험 요약 CSV를 생성합니다.\"\"\"\n",
    "    summary_rows = []\n",
    "    section_map = {\n",
    "        \"metrics\": \"default_model_metrics\",\n",
    "        \"baselines\": \"baseline\",\n",
    "        \"model_comparison_by_seed\": \"model_comparison_by_seed\",\n",
    "        \"model_comparison_summary\": \"model_comparison_summary\",\n",
    "        \"public_model_comparison\": \"public_model_comparison\",\n",
    "    }\n",
    "\n",
    "    for key, section in section_map.items():\n",
    "        for row in metadata.get(key, []):\n",
    "            summary_rows.append({\"section\": section, **row})\n",
    "\n",
    "    return pd.DataFrame(summary_rows)"
