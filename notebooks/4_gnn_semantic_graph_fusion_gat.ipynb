   "outputs": [],
   "source": [
    "def build_relation_type_candidates(nodes_df, train_edges_df, schema_target_edges_df, node2idx, edge_type2idx):\n",
    "    node_type_col = find_col(nodes_df, [\"node_type\", \"type\"], required=False)\n",
    "    if node_type_col is None:\n",
    "        nodes_df = nodes_df.copy()\n",
    "        nodes_df[\"node_type\"] = nodes_df[node_id_col].map(infer_node_type)\n",
    "        node_type_col = \"node_type\"\n",
    "\n",
    "    node_idx_by_type = defaultdict(list)\n",
    "    for _, row in nodes_df.iterrows():\n",
    "        nid = str(row[node_id_col])\n",
    "        if nid in node2idx:\n",
    "            node_idx_by_type[str(row[node_type_col])].append(node2idx[nid])\n",
    "\n",
    "    rel_tail_types = defaultdict(Counter)\n",
    "    rel_head_types = defaultdict(Counter)\n",
    "\n",
    "    # Leakage 방지:\n",
    "    # valid/test target edge를 relation-tail type schema 추정에 사용하지 않습니다.\n",
    "    # candidate pool의 node type은 train graph + train target edge만 보고 추정합니다.\n",
    "    schema_frames = [train_edges_df]\n",
    "    if schema_target_edges_df is not None and len(schema_target_edges_df) > 0:\n",
    "        schema_frames.append(schema_target_edges_df)\n",
    "    merged = pd.concat(schema_frames, ignore_index=True)\n",
    "    node_type_map = nodes_df.set_index(node_id_col)[node_type_col].astype(str).to_dict()\n",
    "\n",
    "    for _, row in merged.iterrows():\n",
    "        rel = str(row[edge_type_col])\n",
    "        s = str(row[source_col])\n",
    "        t = str(row[target_col])\n",
    "        if rel in edge_type2idx:\n",
    "            rel_tail_types[edge_type2idx[rel]][node_type_map.get(t, infer_node_type(t))] += 1\n",
    "            rel_head_types[edge_type2idx[rel]][node_type_map.get(s, infer_node_type(s))] += 1\n",
    "\n",
    "    rel_tail_candidates = {}\n",
    "    rel_head_candidates = {}\n",
    "    all_nodes = list(range(len(nodes_df)))\n",
    "\n",
    "    for rel_idx in range(len(edge_type2idx)):\n",
    "        if len(rel_tail_types[rel_idx]) > 0:\n",
    "            major_tail_type = rel_tail_types[rel_idx].most_common(1)[0][0]\n",
    "            rel_tail_candidates[rel_idx] = node_idx_by_type.get(major_tail_type, all_nodes)\n",
    "        else:\n",
    "            rel_tail_candidates[rel_idx] = all_nodes\n",
    "\n",
    "        if len(rel_head_types[rel_idx]) > 0:\n",
    "            major_head_type = rel_head_types[rel_idx].most_common(1)[0][0]\n",
    "            rel_head_candidates[rel_idx] = node_idx_by_type.get(major_head_type, all_nodes)\n",
    "        else:\n",
    "            rel_head_candidates[rel_idx] = all_nodes\n",
    "\n",
    "    return rel_tail_candidates, rel_head_candidates, dict(node_idx_by_type)"
   ]
  },
