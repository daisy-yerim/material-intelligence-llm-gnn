  {
   "cell_type": "markdown",
   "id": "2cb73bdd",
   "metadata": {},
   "source": [
    "## 6. 메시지별 원인 후보 추천\n",
    "\n",
    "학습된 최종 relation-learning GNN embedding과 relation decoder를 사용해 각 메시지에 대해 다음 후보를 추천합니다.\n",
    "\n",
    "- 관련 품목 번호 후보 (`related_to_part_no`)\n",
    "- 관련 품목 설명 후보 (`related_to_part_desc`)\n",
    "- 관련 제품 후보 (`related_to_product`)\n",
    "- 관련 조직/거점 후보 (`related_to_org`)\n",
    "\n",
    "**문제 원인 후보 탐지 및 의사결정 지원**을 합니다\n"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "id": "e49eb402",
   "metadata": {},
   "outputs": [],
   "source": [
    "@torch.no_grad()\n",
    "def get_final_embeddings(model, x, edge_index, edge_type, device, to_cpu=True):\n",
    "    \"\"\"최종 node embedding을 반환합니다.\n",
    "\n",
    "    추천 점수 계산은 model parameter와 같은 device에서 수행해야 하므로 기본적으로\n",
    "    GPU tensor를 유지할 수 있게 `to_cpu=False` 옵션을 둡니다.\n",
    "    유사도 계산/저장용으로만 CPU copy를 사용합니다.\n",
    "    \"\"\"\n",
    "    model.eval()\n",
    "    z = model.encode(x.to(device), edge_index.to(device), edge_type.to(device))\n",
    "    return z.detach().cpu() if to_cpu else z.detach()\n",
    "\n",
    "def sigmoid_np(a):\n",
    "    return 1.0 / (1.0 + np.exp(-a))\n",
    "\n",
    "def get_observed_edge_set(edges_df):\n",
    "    return set(zip(\n",
    "        edges_df[source_col].astype(str),\n",
    "        edges_df[edge_type_col].astype(str),\n",
    "        edges_df[target_col].astype(str),\n",
    "    ))\n",
    "\n",
    "def node_display_name(node_id):\n",
    "    rows = nodes_df[nodes_df[node_id_col].astype(str).eq(str(node_id))]\n",
    "    if len(rows) == 0:\n",
    "        return str(node_id)\n",
    "    for c in [\"node_name\", \"source_value\"]:\n",
    "        if c in rows.columns:\n",
    "            v = clean_text(rows.iloc[0][c])\n",
    "            if v:\n",
    "                return v\n",
    "    return str(node_id)\n",
    "\n",
    "def message_metadata_by_node():\n",
    "    meta = {}\n",
    "    base = message_df.copy().reset_index(names=\"message_row_i\")\n",
    "    useful_cols = [\n",
    "        \"message_row_i\", \"message_id\", \"source_domain\", \"date\", \"message_type\",\n",
    "        \"message_text\", \"final_cluster\", \"cluster_name_final\", \"problem_type\",\n",
    "        \"interpretation_memo\", \"llm_confidence\",\n",
    "    ]\n",
    "    useful_cols = [c for c in useful_cols if c in base.columns]\n",
    "    for row_i, node_id in enumerate(message_node_ids):\n",
    "        if node_id is not None:\n",
    "            meta[node_id] = base.iloc[row_i][useful_cols].to_dict()\n",
    "    return meta\n",
    "\n",
    "z_device = get_final_embeddings(model, x, edge_index, edge_type, device, to_cpu=False)\n",
    "z = z_device.detach().cpu()  # 유사 메시지 추천/저장용 CPU copy\n",
    "observed_edges = get_observed_edge_set(edges_df)\n",
    "msg_meta = message_metadata_by_node()\n",
    "node_type_map = nodes_df.set_index(node_id_col)[\"node_type\"].astype(str).to_dict()\n",
    "\n",
    "recommend_rows = []\n",
    "\n",
    "for msg_node in [n for n in message_node_ids if n is not None and n in node2idx]:\n",
    "    s_idx = node2idx[msg_node]\n",
    "    meta = msg_meta.get(msg_node, {})\n",
    "\n",
    "    for rel in CONFIG.get(\"recommend_relation_types\", []):\n",
    "        if rel not in edge_type2idx:\n",
    "            continue\n",
    "        r_idx = edge_type2idx[rel]\n",
    "        candidate_indices = rel_tail_candidates.get(r_idx, [])\n",
    "        if len(candidate_indices) == 0:\n",
    "            continue\n",
    "\n",
    "        triples = torch.tensor(\n",
    "            [[s_idx, r_idx, int(t_idx)] for t_idx in candidate_indices],\n",
    "            dtype=torch.long,\n",
    "            device=device,\n",
    "        )\n",
    "        scores = model.score_triples(z_device, triples).detach().cpu().numpy()\n",
    "        probs = sigmoid_np(scores)\n",
    "\n",
    "        order = np.argsort(-scores)\n",
    "        taken = 0\n",
    "        for oi in order:\n",
    "            t_idx = int(candidate_indices[int(oi)])\n",
    "            target_node = idx2node[t_idx]\n",
    "            is_observed = (msg_node, rel, target_node) in observed_edges\n",
    "\n",
    "            # 이미 관측된 edge도 함께 표시합니다. 사후 검증에서 observed 여부로 구분합니다.\n",
    "            recommend_rows.append({\n",
    "                \"message_node_id\": msg_node,\n",
    "                \"message_id\": meta.get(\"message_id\", \"\"),\n",
    "                \"message_text\": meta.get(\"message_text\", \"\"),\n",
    "                \"source_domain\": meta.get(\"source_domain\", \"\"),\n",
    "                \"date\": meta.get(\"date\", \"\"),\n",
    "                \"message_type\": meta.get(\"message_type\", \"\"),\n",
    "                \"cluster_name_final_context\": meta.get(\"cluster_name_final\", \"\"),\n",
    "                \"problem_type_context\": meta.get(\"problem_type\", \"\"),\n",
    "                \"relation\": rel,\n",
    "                \"candidate_node_id\": target_node,\n",
    "                \"candidate_node_type\": node_type_map.get(target_node, infer_node_type(target_node)),\n",
    "                \"candidate_name\": node_display_name(target_node),\n",
    "                \"score\": float(scores[int(oi)]),\n",
    "                \"confidence\": float(probs[int(oi)]),\n",
    "                \"observed_in_original_graph\": bool(is_observed),\n",
    "                \"recommendation_rank\": taken + 1,\n",
    "            })\n",
    "            taken += 1\n",
    "            if taken >= CONFIG[\"top_k_cause_candidates\"]:\n",
    "                break\n",
    "\n",
    "recommend_df = pd.DataFrame(recommend_rows)\n",
    "if len(recommend_df) > 0:\n",
    "    recommend_df[\"message_text_short\"] = recommend_df[\"message_text\"].fillna(\"\").astype(str).str.slice(0, 180)\n",
    "    display(recommend_df.head(20))\n",
    "    print(\"추천 relation 분포\")\n",
    "    display(recommend_df[\"relation\"].value_counts())\n",
    "else:\n",
    "    print(\"추천 결과가 없습니다. recommend_relation_types와 target relation을 확인하세요.\")\n",
    "\n",
    "recommend_df.to_csv(\n",
    "    f\"{CONFIG['out_dir']}/message_cause_candidate_recommendations.csv\",\n",
    "    index=False,\n",
    "    encoding=\"utf-8-sig\",\n",
    ")\n"
   ]
  },
  {
   "cell_type": "markdown",
   "id": "7c044a5f",
   "metadata": {},
   "source": [
    "## 6-1. 자동 선택된 최종 모델 기반 추천\n",
    "\n",
    "현재 `recommend_df`는 위에서 자동 선택된 최종 모델의 `score_triples()` 결과를 기준으로 생성됩니다.\n",
    "\n",
    "즉, 추천 결과는 후처리 점수합이 아니라 학습된 relation scoring model의 점수에 기반합니다.\n",
    "최종 모델명은 `CONFIG['selected_model']`, 내부 모델 키는 `CONFIG['selected_model_type']`에서 확인할 수 있습니다.\n"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "id": "4e6213e7",
   "metadata": {},
   "outputs": [],
   "source": [
    "# 자동 선택된 최종 모델 추천 결과 확인 및 저장\n",
    "\n",
    "if \"recommend_df\" in globals() and len(recommend_df) > 0:\n",
