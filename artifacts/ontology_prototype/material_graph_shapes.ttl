@prefix sh: <http://www.w3.org/ns/shacl#> .
@prefix mi: <http://example.org/material-intelligence#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

mi:MessageShape
    a sh:NodeShape ;
    sh:targetClass mi:Message ;
    sh:property [
        sh:path mi:messageId ;
        sh:minCount 1 ;
        sh:datatype xsd:string ;
    ] ;
    sh:property [
        sh:path mi:messageText ;
        sh:minCount 1 ;
        sh:datatype xsd:string ;
    ] .

mi:MaterialRelationShape
    a sh:NodeShape ;
    sh:targetClass mi:MaterialRelation ;
    sh:property [
        sh:path mi:sourceMessage ;
        sh:minCount 1 ;
        sh:class mi:Message ;
    ] ;
    sh:property [
        sh:path mi:targetEntity ;
        sh:minCount 1 ;
    ] .
