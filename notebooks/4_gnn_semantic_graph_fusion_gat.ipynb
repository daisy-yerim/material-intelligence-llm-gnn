    "## 8-1. Rule 데이터 기반 사후 검증 + 사람 검수 샘플\n",
    "\n",
    "규칙 기반 검증/의사결정 지원 흐름에 맞춰, GNN 추천 후보가 Rule 데이터에 등장하는지 확인합니다.\n",
    "\n",
    "이 검증은 정답 라벨이 아니라 **사후 근거 강화용**입니다. 최종 성능 평가는 사람이 일부 샘플을 검수해 `human_label`을 채운 뒤 Precision@K를 계산하는 방식이 필요합니다.\n"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "def resolve_rule_path():\n",
    "    path, checked = resolve_existing_path_from_candidates(CONFIG.get(\"rule_file_candidates\", []))\n",
    "    if path is None:\n",
    "        print(\"[INFO] Rule 파일을 찾지 못했습니다. 확인 경로 일부:\")\n",
    "        for p in checked[:10]:\n",
    "            print(\" -\", p)\n",
    "    return path"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "def read_rule_excel_auto(path):\n",
    "    last_err = None\n",
    "    for header in CONFIG.get(\"rule_excel_header_candidates\", [2, 1, 0, None]):\n",
    "        try:\n",
    "            df = pd.read_excel(path, engine=\"openpyxl\", header=header)\n",
    "            df.columns = [str(c).strip() for c in df.columns]\n",
    "            # 빈 컬럼/행이 너무 많은 경우 제거\n",
    "            df = df.dropna(how=\"all\").reset_index(drop=True)\n",
    "            if df.shape[0] > 0 and df.shape[1] > 0:\n",
    "                print(f\"[INFO] Rule 파일 로드 성공: header={header}, shape={df.shape}\")\n",
    "                return df, header\n",
    "        except Exception as e:\n",
    "            last_err = e\n",
    "    raise ValueError(f\"Rule Excel 로드 실패: {path}, last_error={last_err}\")"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "def build_rule_text_index(rule_df):\n",
    "    text_cols = []\n",
    "    for c in rule_df.columns:\n",
    "        # object 컬럼 또는 컬럼명상 설명/규칙/품목 관련 가능성이 있는 컬럼을 텍스트 검색 대상으로 사용\n",
    "        if rule_df[c].dtype == \"object\" or any(k in str(c).lower() for k in [\"rule\", \"품\", \"item\", \"part\", \"desc\", \"설명\", \"조건\", \"메시지\", \"message\"]):\n",
    "            text_cols.append(c)\n",
    "    if not text_cols:\n",
    "        text_cols = list(rule_df.columns)\n",
    "    rule_text = rule_df[text_cols].astype(str).fillna(\"\").agg(\" | \".join, axis=1)\n",
    "    return rule_text, text_cols"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "def validate_recommendations_with_rules(recommend_df):\n",
    "    if not CONFIG.get(\"enable_rule_validation\", True) or len(recommend_df) == 0:\n",
    "        return pd.DataFrame()\n",
    "    rule_path = resolve_rule_path()\n",
    "    if rule_path is None:\n",
    "        return pd.DataFrame()\n",
    "\n",
    "    try:\n",
    "        rule_df, used_header = read_rule_excel_auto(rule_path)\n",
    "    except Exception as e:\n",
    "        print(\"[WARN] Rule 파일 로드 실패:\", e)\n",
    "        return pd.DataFrame()\n",
    "\n",
    "    rule_text, text_cols = build_rule_text_index(rule_df)\n",
    "    rows = []\n",
    "    for _, rec in recommend_df.iterrows():\n",
    "        cand = clean_text(rec.get(\"candidate_name\", \"\"))\n",
    "        cand_node = clean_text(rec.get(\"candidate_node_id\", \"\"))\n",
    "        # 너무 짧은 후보는 오탐 방지를 위해 skip\n",
    "        search_terms = [t for t in [cand, cand_node.split(\":\")[-1] if \":\" in cand_node else cand_node] if len(t) >= 3]\n",
    "        match_idx = []\n",
    "        for term in search_terms[:2]:\n",
    "            mask = rule_text.str.contains(re.escape(term), case=False, na=False, regex=True)\n",
    "            match_idx.extend(rule_text[mask].index.tolist()[:5])\n",
    "        match_idx = list(dict.fromkeys(match_idx))\n",
    "        rows.append({\n",
    "            \"message_node_id\": rec.get(\"message_node_id\", \"\"),\n",
    "            \"message_id\": rec.get(\"message_id\", \"\"),\n",
    "            \"relation\": rec.get(\"relation\", \"\"),\n",
    "            \"candidate_node_id\": rec.get(\"candidate_node_id\", \"\"),\n",
    "            \"candidate_name\": cand,\n",
    "            \"confidence\": rec.get(\"confidence\", np.nan),\n",
    "            \"rule_file\": str(rule_path),\n",
    "            \"rule_header\": used_header,\n",
    "            \"rule_text_columns\": \";\".join(map(str, text_cols[:20])),\n",
    "            \"rule_match_count_top5\": len(match_idx),\n",
    "            \"has_rule_match\": len(match_idx) > 0,\n",
    "            \"matched_rule_indices\": \";\".join(map(str, match_idx)),\n",
    "            \"matched_rule_preview\": \" || \".join(rule_text.loc[match_idx].astype(str).str.slice(0, 180).tolist()) if match_idx else \"\",\n",
    "        })\n",
    "    out = pd.DataFrame(rows)\n",
    "    out.to_csv(f\"{CONFIG['out_dir']}/rule_validation_for_recommendations.csv\", index=False, encoding=\"utf-8-sig\")\n",
    "    print(\"Rule validation saved:\", f\"{CONFIG['out_dir']}/rule_validation_for_recommendations.csv\")\n",
    "    display(out.head(20))\n",
    "    print(\"has_rule_match 분포\")\n",
    "    display(out[\"has_rule_match\"].value_counts())\n",
    "    return out"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "rule_validation_df = validate_recommendations_with_rules(recommend_df)"
   ]
