   "source": [
    "def resolve_data_path(filename, base_dir_candidates=None, required=True):\n",
    "    filename = str(filename)\n",
    "    base_dirs = _as_base_dirs(base_dir_candidates)\n",
    "    cwd = Path.cwd()\n",
    "\n",
    "    candidates = []\n",
    "    p = Path(filename).expanduser()\n",
    "    candidates.append(p)\n",
    "\n",
    "    for base_dir in base_dirs:\n",
    "        candidates.append(base_dir / filename)\n",
    "\n",
    "    candidates.extend([\n",
    "        cwd / filename,\n",
    "        cwd.parent / filename,\n",
    "        cwd / \"3.cluster_interpretation\" / filename,\n",
    "        cwd.parent / \"3.cluster_interpretation\" / filename,\n",
    "    ])\n",
    "\n",
    "    seen = set()\n",
    "    unique_candidates = []\n",
    "    for c in candidates:\n",
    "        cs = str(c)\n",
    "        if cs not in seen:\n",
    "            seen.add(cs)\n",
    "            unique_candidates.append(c)\n",
    "\n",
    "    for c in unique_candidates:\n",
    "        if c.exists():\n",
    "            return c\n",
    "\n",
    "    if required:\n",
    "        msg = \"파일을 찾지 못했습니다. 확인한 경로:\\n\" + \"\\n\".join(str(c) for c in unique_candidates)\n",
    "        raise FileNotFoundError(msg)\n",
    "    return None"
   ]
  },
