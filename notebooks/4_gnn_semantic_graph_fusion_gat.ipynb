    "class SemanticGraphFusionGATLinkPredictor(nn.Module):\n",
    "    \"\"\"배포용 최종 모델: Semantic-Graph Fusion GAT.\n",
    "\n",
    "    단순히 TF-IDF 점수와 GNN 점수를 사후 가중합하지 않습니다.\n",
    "    BGE-M3 기반 원본 node feature에서 semantic representation을 만들고,\n",
    "    relation-aware GAT로 graph representation을 만든 뒤,\n",
    "    triple 단위에서 graph score와 semantic score를 Fusion MLP가 학습 결합합니다.\n",
    "\n",
    "    score = learnable_fusion(graph_score, semantic_score, relation_context)\n",
    "    \"\"\"\n",
    "    def __init__(\n",
    "        self,\n",
    "        in_dim,\n",
    "        hidden_dim,\n",
    "        out_dim,\n",
    "        num_relations_for_mp,\n",
    "        num_base_relations,\n",
    "        heads=4,\n",
    "        dropout=0.25,\n",
    "        attention_dropout=0.20,\n",
    "        fusion_hidden_dim=64,\n",
    "        graph_score_scale_init=1.0,\n",
    "        semantic_score_scale_init=1.0,\n",
    "    ):\n",
    "        super().__init__()\n",
    "        if GATv2Conv is None:\n",
    "            raise ImportError(\"torch_geometric.nn.GATv2Conv를 사용할 수 없습니다. torch-geometric 버전을 확인하세요.\")\n",
    "        if hidden_dim % heads != 0:\n",
    "            raise ValueError(f\"hidden_dim({hidden_dim})은 attention_heads({heads})로 나누어떨어져야 합니다.\")\n",
    "        if out_dim % heads != 0:\n",
    "            raise ValueError(f\"out_dim({out_dim})은 attention_heads({heads})로 나누어떨어져야 합니다.\")\n",
    "\n",
    "        self.model_name = \"semantic_graph_fusion_gat\"\n",
    "        self.out_dim = out_dim\n",
    "        self.dropout = dropout\n",
    "\n",
    "        # Semantic branch: BGE-M3 + 보조 node text/type feature에서 의미 표현 생성\n",
    "        self.semantic_proj = nn.Sequential(\n",
    "            nn.Linear(in_dim, hidden_dim),\n",
    "            nn.ReLU(),\n",
    "            nn.Dropout(dropout),\n",
    "            nn.Linear(hidden_dim, out_dim),\n",
    "            nn.LayerNorm(out_dim),\n",
    "        )\n",
    "\n",
    "        # Graph branch: relation-aware GAT\n",
    "        self.input_proj = nn.Linear(in_dim, hidden_dim)\n",
    "        self.edge_emb1 = nn.Embedding(num_relations_for_mp, hidden_dim)\n",
    "        self.edge_emb2 = nn.Embedding(num_relations_for_mp, hidden_dim)\n",
    "        self.gat1 = GATv2Conv(\n",
    "            in_channels=hidden_dim,\n",
    "            out_channels=hidden_dim // heads,\n",
    "            heads=heads,\n",
    "            concat=True,\n",
    "            dropout=attention_dropout,\n",
    "            edge_dim=hidden_dim,\n",
    "            add_self_loops=False,\n",
    "        )\n",
    "        self.gat2 = GATv2Conv(\n",
    "            in_channels=hidden_dim,\n",
    "            out_channels=out_dim // heads,\n",
    "            heads=heads,\n",
    "            concat=True,\n",
    "            dropout=attention_dropout,\n",
    "            edge_dim=hidden_dim,\n",
    "            add_self_loops=False,\n",
    "        )\n",
    "        self.norm1 = nn.LayerNorm(hidden_dim)\n",
    "        self.norm2 = nn.LayerNorm(out_dim)\n",
    "        self.skip2 = nn.Linear(hidden_dim, out_dim)\n",
    "\n",
    "        # Relation-specific graph decoder\n",
    "        self.rel_emb = nn.Embedding(num_base_relations, out_dim)\n",
    "\n",
    "        # 학습 가능한 fusion. 단순 alpha 가중합이 아니라, relation context별로 결합 방식을 학습합니다.\n",
    "        self.graph_score_scale = nn.Parameter(torch.tensor(float(graph_score_scale_init)))\n",
    "        self.semantic_score_scale = nn.Parameter(torch.tensor(float(semantic_score_scale_init)))\n",
    "        self.fusion_mlp = nn.Sequential(\n",
    "            nn.Linear(out_dim + 4, fusion_hidden_dim),\n",
    "            nn.ReLU(),\n",
    "            nn.Dropout(dropout),\n",
    "            nn.Linear(fusion_hidden_dim, 1),\n",
