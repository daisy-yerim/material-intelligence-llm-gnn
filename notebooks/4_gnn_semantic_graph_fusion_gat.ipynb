   "outputs": [],
   "source": [
    "def select_model_from_by_seed(by_seed_df, selection_split, selection_metric):\n",
    "    \"\"\"요약표가 없을 때 seed별 결과표에서 직접 최종 모델을 선택합니다.\"\"\"\n",
    "    selection_df = by_seed_df[by_seed_df[\"split\"].eq(selection_split)].copy()\n",
    "    if not len(selection_df):\n",
    "        return {}\n",
    "\n",
    "    if selection_metric in selection_df.columns:\n",
    "        selection_df = selection_df.sort_values(\n",
    "            [selection_metric, \"best_valid_score\"],\n",
    "            ascending=[False, False],\n",
    "        )\n",
    "    else:\n",
    "        selection_df = selection_df.sort_values([\"best_valid_score\"], ascending=[False])\n",
    "\n",
    "    best_row = selection_df.iloc[0]\n",
    "    return {\n",
    "        \"selection_split\": selection_split,\n",
    "        \"selection_metric\": selection_metric,\n",
    "        \"selected_model_key\": str(best_row[\"model_key\"]),\n",
    "        \"selected_model\": str(best_row[\"model\"]),\n",
    "        \"selected_seed\": int(best_row[\"seed\"]),\n",
    "        \"selection_score\": float(best_row.get(selection_metric, best_row.get(\"best_valid_score\", np.nan))),\n",
    "    }"
   ]
