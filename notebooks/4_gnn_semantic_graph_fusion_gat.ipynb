    "def run_model_comparison_experiments(config):\n",
    "    \"\"\"여러 모델과 seed 조합을 학습·평가하고 비교표를 저장합니다.\"\"\"\n",
    "    comparison_models = {}\n",
    "    comparison_metric_frames = []\n",
    "    comparison_history_frames = []\n",
    "\n",
    "    if not config.get(\"run_model_comparison\", True):\n",
    "        print(\"모델끼리 비교 실험이 비활성화되어 있습니다.\")\n",
    "        return {\n",
    "            \"comparison_models\": comparison_models,\n",
    "            \"model_comparison_df\": pd.DataFrame(),\n",
    "            \"model_comparison_history_df\": pd.DataFrame(),\n",
    "            \"model_comparison_summary_df\": pd.DataFrame(),\n",
    "            \"gnn_model_comparison_df\": pd.DataFrame(),\n",
    "            \"proposed_existing_metrics_df\": pd.DataFrame(),\n",
    "            \"proposed_enhanced_metrics_df\": pd.DataFrame(),\n",
    "            \"proposed_model_metrics_df\": pd.DataFrame(),\n",
    "        }\n",
    "\n",
    "    comparison_seeds = config.get(\"comparison_seeds\", [config[\"seed\"]])\n",
    "\n",
    "    for run_seed in comparison_seeds:\n",
    "        print(\"\\n\\n==============================\")\n",
    "        print(f\"Model comparison seed = {run_seed}\")\n",
    "        print(\"==============================\")\n",
    "\n",
    "        for mt in config.get(\"model_comparison_types\", []):\n",
    "            model_key = canonical_model_key(mt)\n",
    "\n",
    "            if model_key == \"mlp\":\n",
    "                print(\"[SKIP] MLP는 메인 GNN 모델 비교에서 제외합니다.\")\n",
    "                continue\n",
    "\n",
    "            print(\"\\n=== Train / evaluate model:\", model_display_name(model_key), \"| seed:\", run_seed, \"===\")\n",
    "\n",
    "            try:\n",
    "                m_i, metrics_i, hist_i = train_one_link_predictor(\n",
    "                    model_key,\n",
    "                    run_seed=run_seed,\n",
    "                    verbose=True,\n",
    "                )\n",
    "\n",
    "                comparison_models[(model_key, run_seed)] = m_i\n",
    "                comparison_metric_frames.append(metrics_i)\n",
    "                comparison_history_frames.append(hist_i)\n",
    "                display(metrics_i)\n",
    "\n",
    "            except Exception as e:\n",
    "                print(f\"[WARN] {model_display_name(model_key)} | seed={run_seed} 학습/평가 실패: {e}\")\n",
    "\n",
    "    model_comparison_df = (\n",
    "        pd.concat(comparison_metric_frames, ignore_index=True)\n",
    "        if comparison_metric_frames\n",
    "        else pd.DataFrame()\n",
    "    )\n",
    "\n",
    "    model_comparison_history_df = (\n",
    "        pd.concat(comparison_history_frames, ignore_index=True)\n",
    "        if comparison_history_frames\n",
    "        else pd.DataFrame()\n",
    "    )\n",
    "\n",
    "    if len(model_comparison_df):\n",
    "        model_comparison_df = add_model_order_and_sort(\n",
    "            model_comparison_df,\n",
    "            sort_cols=[\"split\", \"model_order\", \"seed\"],\n",
    "        )\n",
    "        display(model_comparison_df)\n",
    "        model_comparison_df.to_csv(\n",
    "            f\"{config['out_dir']}/model_to_model_comparison_by_seed.csv\",\n",
    "            index=False,\n",
    "            encoding=\"utf-8-sig\",\n",
    "        )\n",
    "\n",
    "        model_comparison_summary_df = summarize_model_comparison(model_comparison_df)\n",
    "        display(model_comparison_summary_df)\n",
    "        model_comparison_summary_df.to_csv(\n",
    "            f\"{config['out_dir']}/model_to_model_comparison_summary.csv\",\n",
    "            index=False,\n",
    "            encoding=\"utf-8-sig\",\n",
    "        )\n",
    "\n",
    "        grouped_tables = export_grouped_model_comparison_tables(model_comparison_df, config[\"out_dir\"])\n",
    "    else:\n",
    "        model_comparison_summary_df = pd.DataFrame()\n",
    "        grouped_tables = {\n",
    "            \"gnn_model_comparison_df\": pd.DataFrame(),\n",
    "            \"proposed_existing_metrics_df\": pd.DataFrame(),\n",
    "            \"proposed_enhanced_metrics_df\": pd.DataFrame(),\n",
    "            \"proposed_model_metrics_df\": pd.DataFrame(),\n",
    "        }\n",
    "\n",
    "    if len(model_comparison_history_df):\n",
    "        model_comparison_history_df.to_csv(\n",
    "            f\"{config['out_dir']}/model_to_model_training_history_by_seed.csv\",\n",
    "            index=False,\n",
    "            encoding=\"utf-8-sig\",\n",
    "        )\n",
    "\n",
    "    return {\n",
    "        \"comparison_models\": comparison_models,\n",
    "        \"model_comparison_df\": model_comparison_df,\n",
    "        \"model_comparison_history_df\": model_comparison_history_df,\n",
    "        \"model_comparison_summary_df\": model_comparison_summary_df,\n",
    "        **grouped_tables,\n",
    "    }"
   ]
  },
