   "cell_type": "code",
   "execution_count": null,
   "id": "0c265d95",
   "metadata": {},
   "outputs": [],
   "source": [
    "device = torch.device(\"cuda\" if torch.cuda.is_available() else \"cpu\")\n",
    "print(\"device:\", device)\n",
    "print(\"model_type:\", CONFIG.get(\"model_type\"))\n",
    "\n",
    "model = build_link_predictor_model().to(device)\n",
    "print(model)\n",
    "\n",
    "optimizer = torch.optim.AdamW(\n",
    "    model.parameters(),\n",
    "    lr=CONFIG[\"lr\"],\n",
    "    weight_decay=CONFIG[\"weight_decay\"],\n",
    ")\n",
    "\n",
    "x_device = x.to(device)\n",
    "edge_index_device = edge_index.to(device)\n",
    "edge_type_device = edge_type.to(device)\n",
    "\n",
    "history = []\n",
    "best_state = None\n",
    "best_score = -np.inf\n",
    "patience_counter = 0\n",
    "\n",
    "def compute_link_prediction_loss(pos_scores, neg_scores):\n",
    "    scores = torch.cat([pos_scores, neg_scores], dim=0)\n",
    "    labels = torch.cat([\n",
    "        torch.ones_like(pos_scores),\n",
    "        torch.zeros_like(neg_scores),\n",
    "    ], dim=0)\n",
    "\n",
    "    if CONFIG.get(\"use_balanced_bce_pos_weight\", True) and len(pos_scores) > 0:\n",
    "        pos_weight = torch.tensor([max(1.0, len(neg_scores) / max(1, len(pos_scores)))], device=scores.device)\n",
    "        bce_loss = F.binary_cross_entropy_with_logits(scores, labels, pos_weight=pos_weight)\n",
    "    else:\n",
    "        bce_loss = F.binary_cross_entropy_with_logits(scores, labels)\n",
    "\n",
    "    ranking_weight = float(CONFIG.get(\"ranking_loss_weight\", 0.0))\n",
    "    if ranking_weight > 0 and len(neg_scores) > 0 and len(pos_scores) > 0:\n",
    "        k = max(1, len(neg_scores) // len(pos_scores))\n",
    "        pos_for_rank = pos_scores.repeat_interleave(k)\n",
    "        neg_for_rank = neg_scores[:len(pos_for_rank)]\n",
    "        target = torch.ones_like(pos_for_rank)\n",
    "        rank_loss = F.margin_ranking_loss(\n",
    "            pos_for_rank,\n",
    "            neg_for_rank,\n",
    "            target,\n",
    "            margin=float(CONFIG.get(\"ranking_margin\", 1.0)),\n",
    "        )\n",
    "        return bce_loss + ranking_weight * rank_loss, bce_loss.detach(), rank_loss.detach()\n",
    "\n",
    "    return bce_loss, bce_loss.detach(), torch.tensor(0.0, device=scores.device)\n",
    "\n",
    "for epoch in range(1, CONFIG[\"epochs\"] + 1):\n",
    "    model.train()\n",
    "    optimizer.zero_grad()\n",
    "\n",
    "    neg_triples = sample_negative_triples(\n",
    "        train_triples,\n",
    "        num_nodes=len(node2idx),\n",
    "        rel_tail_candidates=rel_tail_candidates,\n",
    "        positive_set=positive_set,\n",
    "        negatives_per_positive=CONFIG[\"negatives_per_positive\"],\n",
    "        seed=CONFIG[\"seed\"] + epoch,\n",
    "    )\n",
    "\n",
    "    pos_scores, _ = model(x_device, edge_index_device, edge_type_device, train_triples.to(device))\n",
    "    neg_scores, _ = model(x_device, edge_index_device, edge_type_device, neg_triples.to(device))\n",
    "\n",
    "    loss, bce_loss, rank_loss = compute_link_prediction_loss(pos_scores, neg_scores)\n",
    "    loss.backward()\n",
    "    torch.nn.utils.clip_grad_norm_(model.parameters(), max_norm=5.0)\n",
    "    optimizer.step()\n",
    "\n",
    "    if epoch == 1 or epoch % 5 == 0:\n",
    "        valid_bin = evaluate_binary(model, x, edge_index, edge_type, valid_triples, valid_neg_triples, device)\n",
    "        valid_rank = evaluate_ranking(\n",
    "            model, x, edge_index, edge_type, valid_triples,\n",
    "            rel_tail_candidates, positive_set, device,\n",
    "            num_candidates=CONFIG[\"rank_num_candidates\"],\n",
    "            hits_ks=CONFIG[\"hits_ks\"],\n",
    "            seed=CONFIG[\"seed\"] + 1000 + epoch,\n",
    "        )\n",
    "        valid_score = valid_rank.get(\"mrr\", np.nan)\n",
    "        if np.isnan(valid_score):\n",
    "            valid_score = valid_bin.get(\"auc\", 0.0)\n",
    "\n",
    "        row = {\n",
    "            \"epoch\": epoch,\n",
    "            \"loss\": float(loss.item()),\n",
    "            \"bce_loss\": float(bce_loss.item()),\n",
    "            \"rank_loss\": float(rank_loss.item()),\n",
    "            **{f\"valid_{k}\": v for k, v in valid_bin.items()},\n",
    "            **{f\"valid_{k}\": v for k, v in valid_rank.items()},\n",
    "        }\n",
    "        history.append(row)\n",
    "\n",
    "        if valid_score > best_score:\n",
    "            best_score = valid_score\n",
    "            best_state = {\n",
    "                \"epoch\": epoch,\n",
    "                \"model_state\": {k: v.detach().cpu().clone() for k, v in model.state_dict().items()},\n",
    "                \"valid_score\": float(valid_score),\n",
    "                \"row\": row,\n",
    "            }\n",
    "            patience_counter = 0\n",
    "        else:\n",
    "            patience_counter += 5\n",
    "\n",
    "        if epoch == 1 or epoch % 20 == 0:\n",
    "            print(\n",
    "                f\"Epoch {epoch:03d} | Loss {loss.item():.4f} | BCE {bce_loss.item():.4f} | Rank {rank_loss.item():.4f} | \"\n",
    "                f\"Valid AUC {valid_bin.get('auc', np.nan):.4f} | \"\n",
    "                f\"Valid AP {valid_bin.get('ap', np.nan):.4f} | \"\n",
    "                f\"Valid MRR {valid_rank.get('mrr', np.nan):.4f}\"\n",
    "            )\n",
    "\n",
    "        if patience_counter >= CONFIG[\"patience\"]:\n",
    "            print(\"Early stopping:\", epoch)\n",
    "            break\n",
    "\n",
    "if best_state is None:\n",
    "    raise RuntimeError(\"best_state가 생성되지 않았습니다. target edge 수를 확인하세요.\")\n",
    "\n",
    "model.load_state_dict(best_state[\"model_state\"])\n",
    "model.to(device)\n",
    "print(\"Best epoch:\", best_state[\"epoch\"])\n",
    "print(\"Best validation score:\", best_state[\"valid_score\"])\n"
   ]
  },
