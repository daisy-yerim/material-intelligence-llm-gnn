    "def make_node_text_svd_features(node_texts):\n",
    "    if not CONFIG.get(\"add_node_text_tfidf_feature\", True):\n",
    "        return np.zeros((len(node_texts), 0), dtype=np.float32), {\"node_text_feature_source\": \"disabled\", \"node_text_feature_dim\": 0}\n",
    "\n",
    "    vectorizer = TfidfVectorizer(\n",
    "        max_features=CONFIG.get(\"tfidf_max_features\", 8000),\n",
    "        ngram_range=(1, 2),\n",
    "        min_df=1,\n",
    "    )\n",
    "    tfidf = vectorizer.fit_transform(node_texts)\n",
    "    n_components = min(\n",
    "        CONFIG.get(\"node_text_svd_dim\", 64),\n",
    "        max(1, tfidf.shape[1] - 1),\n",
    "        max(1, tfidf.shape[0] - 1),\n",
    "    )\n",
    "    if n_components >= 2:\n",
    "        svd = TruncatedSVD(n_components=n_components, random_state=CONFIG[\"seed\"])\n",
    "        feat = svd.fit_transform(tfidf).astype(np.float32)\n",
    "        explained = float(svd.explained_variance_ratio_.sum())\n",
    "    else:\n",
    "        feat = tfidf.toarray().astype(np.float32)\n",
    "        explained = np.nan\n",
    "    if CONFIG.get(\"normalize_features\", True) and feat.shape[1] > 0:\n",
    "        feat = l2_normalize_np(feat)\n",
    "    return feat, {\n",
    "        \"node_text_feature_source\": \"tfidf_svd_node_text\",\n",
    "        \"node_text_feature_dim\": int(feat.shape[1]),\n",
    "        \"node_text_svd_explained_variance\": explained,\n",
    "    }"
   ]
  },
