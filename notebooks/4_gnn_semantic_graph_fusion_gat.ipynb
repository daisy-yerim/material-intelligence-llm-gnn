    "        nn.init.xavier_uniform_(self.rel_emb.weight)\n",
    "        nn.init.xavier_uniform_(self.semantic_rel_emb.weight)\n",
    "        nn.init.xavier_uniform_(self.skip2.weight)\n",
    "        nn.init.zeros_(self.skip2.bias)\n",
    "        for m in self.fusion_mlp:\n",
    "            if isinstance(m, nn.Linear):\n",
    "                nn.init.xavier_uniform_(m.weight)\n",
    "                nn.init.zeros_(m.bias)\n",
    "\n",
    "    def encode_semantic(self, x):\n",
    "        return F.normalize(self.semantic_proj(x) + self.semantic_skip(x), p=2, dim=-1)\n",
    "\n",
    "    def encode_graph(self, x, edge_index, edge_type):\n",
    "        h0 = self.input_proj(x)\n",
    "        h0 = F.relu(h0)\n",
    "        h0 = F.dropout(h0, p=self.dropout, training=self.training)\n",
    "\n",
    "        e1 = self.edge_emb1(edge_type)\n",
    "        h1 = self.gat1(h0, edge_index, edge_attr=e1)\n",
    "        h1 = self.norm1(h1 + h0)\n",
    "        h1 = F.relu(h1)\n",
    "        h1 = F.dropout(h1, p=self.dropout, training=self.training)\n",
    "\n",
    "        e2 = self.edge_emb2(edge_type)\n",
    "        graph_z = self.gat2(h1, edge_index, edge_attr=e2)\n",
    "        graph_z = self.norm2(graph_z + self.skip2(h1))\n",
    "        return graph_z\n",
    "\n",
    "    def encode(self, x, edge_index, edge_type):\n",
    "        graph_z = self.encode_graph(x, edge_index, edge_type)\n",
    "        semantic_z = self.encode_semantic(x)\n",
    "        return torch.cat([graph_z, semantic_z], dim=-1)\n",
    "\n",
    "    @torch.no_grad()\n",
    "    def encode_with_attention(self, x, edge_index, edge_type):\n",
    "        self.eval()\n",
    "        semantic_z = self.encode_semantic(x)\n",
    "\n",
    "        h0 = self.input_proj(x)\n",
    "        h0 = F.relu(h0)\n",
    "        e1 = self.edge_emb1(edge_type)\n",
    "        h1, attn1 = self.gat1(h0, edge_index, edge_attr=e1, return_attention_weights=True)\n",
    "        h1 = self.norm1(h1 + h0)\n",
    "        h1 = F.relu(h1)\n",
    "\n",
    "        e2 = self.edge_emb2(edge_type)\n",
    "        graph_z, attn2 = self.gat2(h1, edge_index, edge_attr=e2, return_attention_weights=True)\n",
    "        graph_z = self.norm2(graph_z + self.skip2(h1))\n",
    "        z = torch.cat([graph_z, semantic_z], dim=-1)\n",
    "        return z, {\"layer1\": attn1, \"layer2\": attn2}\n",
    "\n",
    "    def _split_z(self, z):\n",
    "        graph_z = z[:, :self.out_dim]\n",
    "        semantic_z = z[:, self.out_dim:self.out_dim * 2]\n",
    "        return graph_z, semantic_z\n",
    "\n",
    "    def score_triples(self, z, triples):\n",
    "        graph_z, semantic_z = self._split_z(z)\n",
    "        s = triples[:, 0]\n",
    "        r = triples[:, 1]\n",
    "        t = triples[:, 2]\n",
    "\n",
    "        rel = self.rel_emb(r)\n",
    "        sem_rel = self.semantic_rel_emb(r)\n",
    "\n",
    "        graph_pair = graph_z[s] * graph_z[t]\n",
