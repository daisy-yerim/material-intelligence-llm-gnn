    "## 2. Relation target 구성\n",
    "\n",
    "여기서는 `final_cluster`, `cluster_name_final`, `problem_type`을 예측하지 않습니다.\n",
    "\n",
    "대신 다음 관계를 숨겨두고 R-GCN이 복원하도록 학습합니다.\n",
    "\n",
    "- `related_to_part_no`\n",
    "- `related_to_part_desc`\n",
    "- `related_to_product`\n",
    "- `related_to_org`\n",
    "- `next_message_in_domain`\n"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "id": "d37ca9e9",
   "metadata": {},
   "outputs": [],
   "source": [
    "def choose_target_relations(edges_df):\n",
    "    edge_type_col = find_col(edges_df, [\"edge_type\", \"relation\", \"rel_type\"])\n",
    "    counts = edges_df[edge_type_col].value_counts()\n",
    "\n",
    "    preferred = [\n",
    "        r for r in CONFIG.get(\"preferred_target_edge_types\", [])\n",
    "        if r in counts.index and counts[r] >= CONFIG.get(\"min_edges_per_target_relation\", 5)\n",
    "    ]\n",
    "\n",
    "    if len(preferred) == 0:\n",
    "        excluded = set(CONFIG.get(\"context_only_edge_types\", [])) | {\"belongs_to_cluster\", \"cluster_transition_in_domain\"}\n",
    "        candidates = [\n",
    "            r for r, c in counts.items()\n",
    "            if r not in excluded and c >= CONFIG.get(\"min_edges_per_target_relation\", 5)\n",
    "        ]\n",
    "        preferred = candidates[:CONFIG.get(\"max_target_relations\", 8)]\n",
    "\n",
    "    if len(preferred) == 0:\n",
    "        raise ValueError(\n",
    "            \"link prediction 학습에 사용할 target relation이 없습니다. \"\n",
    "            \"3번에서 part/org/product/message sequence edge가 생성됐는지 확인하세요.\"\n",
    "        )\n",
    "    return preferred\n",
    "\n",
    "def stratified_edge_split(target_edges, valid_size=0.15, test_size=0.15, seed=42):\n",
    "    # relation별 비율을 최대한 보존하면서 train/valid/test edge split.\n",
    "    target_edges = target_edges.reset_index(drop=True).copy()\n",
    "    rel_col = find_col(target_edges, [\"edge_type\", \"relation\", \"rel_type\"])\n",
    "\n",
    "    train_parts, valid_parts, test_parts = [], [], []\n",
    "    rng = np.random.default_rng(seed)\n",
    "\n",
    "    for rel, g in target_edges.groupby(rel_col):\n",
    "        idx = np.arange(len(g))\n",
    "        rng.shuffle(idx)\n",
    "        g = g.iloc[idx].reset_index(drop=True)\n",
    "        n = len(g)\n",
    "        if n < 10:\n",
    "            # 너무 작은 relation은 train에만 둡니다. 평가 왜곡 방지.\n",
    "            train_parts.append(g)\n",
    "            continue\n",
    "        n_test = max(1, int(round(n * test_size)))\n",
    "        n_valid = max(1, int(round(n * valid_size)))\n",
    "        if n_test + n_valid >= n:\n",
    "            n_test = max(1, n // 5)\n",
    "            n_valid = max(1, n // 5)\n",
    "        test_parts.append(g.iloc[:n_test])\n",
    "        valid_parts.append(g.iloc[n_test:n_test+n_valid])\n",
    "        train_parts.append(g.iloc[n_test+n_valid:])\n",
    "\n",
    "    train_df = pd.concat(train_parts, ignore_index=True) if train_parts else pd.DataFrame(columns=target_edges.columns)\n",
    "    valid_df = pd.concat(valid_parts, ignore_index=True) if valid_parts else pd.DataFrame(columns=target_edges.columns)\n",
    "    test_df = pd.concat(test_parts, ignore_index=True) if test_parts else pd.DataFrame(columns=target_edges.columns)\n",
    "    return train_df, valid_df, test_df\n",
    "\n",
    "target_relations = choose_target_relations(edges_df)\n",
    "CONFIG[\"target_edge_types\"] = target_relations\n",
    "\n",
    "context_only = set(CONFIG.get(\"context_only_edge_types\", []))\n",
    "\n",
    "is_target_edge = edges_df[edge_type_col].isin(target_relations)\n",
    "target_edges_df = edges_df[is_target_edge].copy()\n",
    "context_edges_df = edges_df[~is_target_edge].copy() if CONFIG.get(\"use_context_edges\", True) else pd.DataFrame(columns=edges_df.columns)\n",
    "\n",
    "train_target_df, valid_target_df, test_target_df = stratified_edge_split(\n",
    "    target_edges_df,\n",
    "    valid_size=CONFIG[\"valid_size\"],\n",
    "    test_size=CONFIG[\"test_size\"],\n",
    "    seed=CONFIG[\"seed\"],\n",
    ")\n",
    "\n",
    "# 학습 그래프에는 context edge 전체 + train target edge만 포함합니다.\n",
    "train_graph_edges_df = pd.concat([context_edges_df, train_target_df], ignore_index=True)\n",
    "\n",
    "print(\"target_relations:\", target_relations)\n",
    "print(\"context edge 수:\", len(context_edges_df))\n",
    "print(\"target edge split:\", {\n",
    "    \"train\": len(train_target_df),\n",
    "    \"valid\": len(valid_target_df),\n",
    "    \"test\": len(test_target_df),\n",
    "})\n",
    "\n",
    "print(\"\\nTarget relation split count\")\n",
    "display(pd.DataFrame({\n",
    "    \"train\": train_target_df[edge_type_col].value_counts(),\n",
    "    \"valid\": valid_target_df[edge_type_col].value_counts(),\n",
    "    \"test\": test_target_df[edge_type_col].value_counts(),\n",
    "}).fillna(0).astype(int))\n"
   ]
  },
