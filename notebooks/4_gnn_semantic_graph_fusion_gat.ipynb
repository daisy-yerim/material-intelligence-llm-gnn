    "def edge_tuple_set(df):\n",
    "    return set(zip(df[source_col].astype(str), df[edge_type_col].astype(str), df[target_col].astype(str)))\n",
    "\n",
    "train_graph_set = edge_tuple_set(train_graph_edges_df)\n",
    "valid_set = edge_tuple_set(valid_target_df)\n",
    "test_set = edge_tuple_set(test_target_df)\n",
    "\n",
    "leaked_valid = train_graph_set & valid_set\n",
    "leaked_test = train_graph_set & test_set\n",
    "\n",
    "print(\"leaked_valid_edges:\", len(leaked_valid))\n",
    "print(\"leaked_test_edges:\", len(leaked_test))\n",
    "\n",
    "if len(leaked_valid) > 0 or len(leaked_test) > 0:\n",
    "    raise ValueError(\"valid/test target edge가 train graph에 포함되어 있습니다. split 구성을 확인하세요.\")\n",
    "else:\n",
    "    print(\"[OK] valid/test target edge는 message passing graph에서 숨겨져 있습니다.\")\n"
