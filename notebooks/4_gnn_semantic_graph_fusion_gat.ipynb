    "\n",
    "    return (\n",
    "        comparison_df\n",
    "        .sort_values(sort_cols)\n",
    "        .drop(columns=[\"model_order\"], errors=\"ignore\")\n",
    "        .reset_index(drop=True)\n",
    "    )"
